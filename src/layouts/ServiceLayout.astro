---
import Layout from "./Layout.astro";
import { getCollection } from 'astro:content';
import SidebarPossibilities from "@/components/Possibilities/SidebarPossibilities.astro";
import Breadcrumb from "@/components/Shared/Breadcrumb.astro";

interface Props {
    service: any;
    sortedServices: any[];
}

const { service, sortedServices } = Astro.props;
const { title, description, image, features, whatWeDo, whatWeDoList, benefits, faqs } = service.data;

const schema = {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": title,
    "description": description || title,
    "provider": {
        "@type": "Organization",
        "name": "BotSync",
        "url": "https://botsync.ru"
    },
    "image": new URL(image, Astro.site || "https://botsync.ru").toString()
};

const breadcrumbItems = [
    { name: "Главная", url: "/" },
    { name: "Возможности", url: "/possibilities" },
    { name: "Детали" }
];
---

<Layout title={title} description={description} ogImage={image} schema={schema} type="article">
    <Breadcrumb title={title} items={breadcrumbItems} />

    <!-- service single section start -->
    <section class="service-single-section pt-100 md-pt-80 pb-100 md-pb-80">
        <div class="container">
            <div class="row">
                <div class="col-lg-12">
                    <div class="service-single-media wow fadeInUp" data-wow-delay=".3s">
                        <figure class="image-anime">
                            <img src={image} alt={title}>
                        </figure>
                    </div>
                </div>
            </div>
            <div class="row flex-lg-row-reverse">
                <div class="col-xl-8 col-md-12 order-lg-2">
                    <div class="service-single-post wow fadeInUp" data-wow-delay=".3s">
                        <div class="service-single-contain">
                            <div class="service-entry-content">
                                <h2>{title}</h2>
                                <slot />

                                {features && (
                                    <>
                                        <h3 class="pt-20">Включенные функции</h3>
                                        <div class="check-list mb-20">
                                            <ul>
                                                {features.map((feature: unknown) => (
                                                    <li>{feature}</li>
                                                ))}
                                            </ul>
                                        </div>
                                    </>
                                )}

                                {whatWeDo && (
                                    <>
                                        <h3 class="pt-20">Что мы делаем?</h3>
                                        <p>{whatWeDo}</p>
                                        {whatWeDoList && (
                                            <div class="check-list mb-20">
                                                <ul>
                                                    {whatWeDoList.map((item: unknown) => (
                                                        <li>{item}</li>
                                                    ))}
                                                </ul>
                                            </div>
                                        )}
                                    </>
                                )}

                                {benefits && (
                                    <>
                                        <h3 class="pt-20">Преимущества наших решений</h3>
                                        <div class="row benifits-wapper">
                                            {benefits.map((benefit: { icon: string | null | undefined; title: unknown; description: unknown; }) => (
                                                <div class="col-xl-6 col-lg-6 col-md-12 col-sm-12">
                                                    <div class="benifits-item">
                                                        <div class="benifits-content">
                                                            <i class={benefit.icon}></i>
                                                            <h4>{benefit.title}</h4>
                                                            <p>{benefit.description}</p>
                                                        </div>
                                                    </div>
                                                </div>
                                            ))}
                                        </div>
                                    </>
                                )}

                                {faqs && (
                                    <>
                                        <h3 class="pt-20">Часто задаваемые вопросы</h3>
                                        <div class="accordion" id="accordionExample">
                                            {faqs.map((faq: { question: unknown; answer: unknown; }, index: number) => (
                                                <div class="accordion-item">
                                                    <h2 class="accordion-header" id={`heading${index}`}>
                                                        <button class={`accordion-button ${index !== 0 ? 'collapsed' : ''}`} type="button" data-bs-toggle="collapse" data-bs-target={`#collapse${index}`} aria-expanded={index === 0 ? "true" : "false"} aria-controls={`collapse${index}`}>
                                                            {faq.question}
                                                        </button>
                                                    </h2>
                                                    <div id={`collapse${index}`} class={`accordion-collapse collapse ${index === 0 ? 'show' : ''}`} data-bs-parent="#accordionExample">
                                                        <div class="accordion-body">
                                                            <div class="inner">
                                                                <div class="accordion-content">
                                                                    <p>{faq.answer}</p>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            ))}
                                        </div>
                                    </>
                                )}
                            </div>
                        </div>
                    </div>
                </div>
                <SidebarPossibilities sortedServices={sortedServices} service={service}/>
            </div>
        </div>
    </section>
    <!-- service single section end -->
</Layout>
