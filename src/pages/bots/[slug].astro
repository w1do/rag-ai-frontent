---
import Layout from "@/layouts/Layout.astro";
import Cta from "@/components/Shared/Cta.astro";
import Breadcrumb from "@/components/Shared/Breadcrumb.astro";
import AIChat from "@/components/Shared/react/AIChat/AIChat.tsx";

const API_BASE = "https://api.botsync.ru";

interface Bot {
    id: number;
    name: string;
    slug: string;
    description?: string;
    status?: string;
    brand_name?: string;
    phone?: string;
    social?: { vk?: string; telegram?: string };
    welcome_message?: string;
    actions?: string[];
    knowledge_count?: number;
}

// Получаем данные конкретного бота по slug через поиск ассистентов.
async function fetchBotBySlug(slug: string): Promise<Bot | null> {
    try {
        const url = `${API_BASE}/api/v1/assistants/search?filter%5Bslug%5D=${encodeURIComponent(slug)}`;
        const res = await fetch(url, { headers: { accept: "application/json" } });
        if (!res.ok) return null;
        const json = await res.json();
        const list: Bot[] = json.data || [];
        return list.find((b) => b.slug === slug) || list[0] || null;
    } catch (e) {
        console.error("Error fetching bot by slug:", slug, e);
        return null;
    }
}

export async function getStaticPaths() {
    let chats: Bot[] = [];
    try {
        const res = await fetch("https://api.botsync.ru/api/chats", {
            headers: { accept: "application/json" }
        });
        if (res.ok) {
            const data = await res.json();
            chats = data.data || [];
        }
    } catch (e) {
        console.error("Error fetching chats for static paths:", e);
    }

    return chats
        .filter((chat) => chat.slug)
        .map((chat) => ({
            params: { slug: chat.slug },
            props: { bot: chat }
        }));
}

const { bot } = Astro.props as { bot: Bot };

// Дополнительно подтягиваем полные данные бота по slug (поиск по адресу /assistants/search).
const fresh = await fetchBotBySlug(bot.slug);
const data: Bot = fresh || bot;

const name = data.name;
const brand = data.brand_name || name;
const niche = data.description || "";

// SEO: Тайтл «Умный чат бот : {name} | BotSync» (суффикс « | BotSync» добавляет Layout).
const seoTitle = `Умный чат бот : ${name}`;
const seoDescription = niche
    ? `Умный чат бот ${name} от ${brand} — нейросеть на базе RAG, которая отвечает на вопросы онлайн 24/7. ${niche}. Пообщайтесь с ИИ-ассистентом ${name} прямо в браузере: чат бот ии онлайн без регистрации.`
    : `Умный чат бот ${name} — ИИ-ассистент на базе нейросети и RAG. Задайте вопрос и общайтесь с чат ботом ${name} онлайн: быстрые ответы 24/7, бесплатно и без регистрации.`;

const canonicalURL = new URL(`/bots/${data.slug}`, Astro.site || "https://botsync.ru");

const breadcrumbItems = [
    { name: "Главная", url: "/" },
    { name: "Каталог ботов", url: "/bots" },
    { name }
];

// JSON-LD: разговорное ИИ-приложение (чат бот / нейросеть).
const botSchema = {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": `${name} — умный чат бот`,
    "applicationCategory": "BusinessApplication",
    "operatingSystem": "Web",
    "url": canonicalURL.toString(),
    "description": seoDescription,
    "creator": {
        "@type": "Organization",
        "name": "BotSync",
        "url": "https://botsync.ru"
    },
    "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "RUB"
    }
};

const faqSchema = {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
        {
            "@type": "Question",
            "name": `Что умеет чат бот ${name}?`,
            "acceptedAnswer": {
                "@type": "Answer",
                "text": `${name} — это умный ИИ чат бот на базе нейросети и технологии RAG. Он отвечает на вопросы по теме «${niche || brand}», работает онлайн 24/7 и общается на естественном языке.`
            }
        },
        {
            "@type": "Question",
            "name": `Как пообщаться с нейросетью ${name} онлайн?`,
            "acceptedAnswer": {
                "@type": "Answer",
                "text": `Просто напишите сообщение в чат на этой странице. Чат бот ${name} ответит мгновенно — бесплатно и без регистрации.`
            }
        },
        {
            "@type": "Question",
            "name": "Можно ли создать такого же умного бота для своего бизнеса?",
            "acceptedAnswer": {
                "@type": "Answer",
                "text": "Да. BotSync позволяет создать ИИ чат бота с базой знаний (RAG), обучить его на ваших документах и внедрить на сайт за несколько минут."
            }
        }
    ]
};

const quickQuestions = (data.actions && data.actions.length > 0)
    ? data.actions
    : ["Чем ты можешь помочь?", "Как это работает?", "Расскажи подробнее"];
---

<Layout
    title={seoTitle}
    description={seoDescription}
    canonicalURL={canonicalURL}
    schema={[botSchema, faqSchema]}
>
    <Breadcrumb title={`Умный чат бот ${name}`} items={breadcrumbItems} />

    <!-- intro / описание бота start -->
    <section class="bot-intro pt-100 md-pt-80 pb-50 md-pb-40">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-lg-9 text-center">
                    <div class="section-title align-items-center">
                        <span class="sub-title">Живое общение с нейросетью</span>
                        <h2>Умный чат бот <span>{name}</span> онлайн</h2>
                        <p class="desc">
                            {name} — это ИИ чат бот на базе нейросети и технологии RAG.
                            {niche ? ` ${niche}.` : ""} Задайте вопрос и пообщайтесь с
                            искусственным интеллектом прямо в браузере — быстрые ответы 24/7,
                            бесплатно и без регистрации.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </section>
    <!-- intro / описание бота end -->

    <!-- AI chat start -->
    <AIChat
        client:load
        chatId={data.id}
        title={`${brand} — ИИ-ассистент`}
        subtitle={niche || "Онлайн-помощник на базе нейросети"}
        greeting={data.welcome_message || `Здравствуйте! Я — умный чат бот ${name}. Задайте мне любой вопрос.`}
    />
    <!-- AI chat end -->

    <!-- semantics / landing-copy start -->
    <section class="bot-about pt-80 md-pt-60 pb-50 md-pb-40">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-lg-10">
                    <h2 class="bot-about__title">Чат с ИИ-ассистентом {name}: нейросеть, которая отвечает на вопросы</h2>
                    <p>
                        Хотите поговорить с искусственным интеллектом? Чат бот {name} — это умный
                        онлайн-собеседник на базе нейросети. Он понимает естественный язык, ведёт
                        диалог и мгновенно отвечает на вопросы по теме «{niche || brand}». Никакой
                        регистрации и установки приложений: общение с ботом доступно прямо на сайте.
                    </p>
                    <p>
                        В отличие от обычных скриптовых ботов, {name} построен на технологии RAG
                        (Retrieval-Augmented Generation). Это значит, что нейросеть отвечает не
                        «из головы», а опирается на проверенную базу знаний — поэтому ответы ИИ
                        чат бота точные и по делу.
                    </p>

                    <div class="row mt-40">
                        <div class="col-md-6">
                            <div class="bot-feature">
                                <h3><i class="fa-solid fa-bolt"></i> Чат бот онлайн 24/7</h3>
                                <p>
                                    ИИ-ассистент {name} на связи круглосуточно. Переписка с ботом
                                    идёт в режиме реального времени — задайте вопрос нейросети и
                                    получите ответ за секунды.
                                </p>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="bot-feature">
                                <h3><i class="fa-solid fa-brain"></i> Умные ответы на базе RAG</h3>
                                <p>
                                    Нейросеть чат бот обучена на данных бренда {brand}. Бот отвечает
                                    на вопросы, опираясь на актуальную базу знаний, а не на
                                    обобщённые данные из интернета.
                                </p>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="bot-feature">
                                <h3><i class="fa-solid fa-comments"></i> Живое общение с нейросетью</h3>
                                <p>
                                    {name} общается как человек: понимает контекст переписки,
                                    уточняет детали и помогает решить ваш вопрос. Это удобный
                                    виртуальный собеседник для бизнеса и клиентов.
                                </p>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="bot-feature">
                                <h3><i class="fa-solid fa-gift"></i> Бесплатно и без регистрации</h3>
                                <p>
                                    Пообщаться с ИИ можно бесплатно и без регистрации. Просто
                                    начните чат с ботом {name} — никаких СМС и анкет не требуется.
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
    <!-- semantics / landing-copy end -->

    <!-- how to start start -->
    <section class="bot-howto pb-80 md-pb-60">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-lg-10">
                    <h2 class="bot-about__title">Как пообщаться с чат ботом {name}</h2>
                    <ol class="bot-steps">
                        <li>Напишите сообщение в поле чата выше или выберите готовый вопрос.</li>
                        <li>Умный ИИ-ассистент {name} обработает запрос с помощью нейросети.</li>
                        <li>Получите развёрнутый ответ и продолжайте диалог с ботом онлайн.</li>
                    </ol>

                    {quickQuestions.length > 0 && (
                        <div class="bot-suggest">
                            <h3>О чём можно спросить нейросеть {name}:</h3>
                            <ul class="bot-suggest__list">
                                {quickQuestions.map((q) => (
                                    <li>«{q}»</li>
                                ))}
                            </ul>
                        </div>
                    )}

                    <p class="mt-30">
                        Хотите такой же умный чат бот для своего бизнеса? BotSync создаёт ИИ
                        чат-ботов с базой знаний (RAG), обучает нейросеть на ваших документах и
                        внедряет ассистента на сайт. Это автоматизация поддержки и продаж с
                        помощью искусственного интеллекта — закажите чат бота под ваши задачи.
                    </p>
                </div>
            </div>
        </div>
    </section>
    <!-- how to start end -->

    <Cta />
</Layout>

<style>
    .bot-about__title {
        margin-bottom: 20px;
    }

    .bot-feature {
        margin-bottom: 30px;
    }

    .bot-feature h3 {
        font-size: 20px;
        margin-bottom: 10px;
    }

    .bot-feature h3 i {
        margin-right: 8px;
        color: var(--primary-color, #6a5af9);
    }

    .bot-steps {
        padding-left: 20px;
        margin-bottom: 30px;
    }

    .bot-steps li {
        margin-bottom: 10px;
    }

    .bot-suggest__list {
        list-style: none;
        padding: 0;
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
    }

    .bot-suggest__list li {
        background: rgba(106, 90, 249, 0.08);
        border-radius: 8px;
        padding: 8px 14px;
        font-size: 15px;
    }

    .mt-40 {
        margin-top: 40px;
    }

    .mt-30 {
        margin-top: 30px;
    }
</style>
