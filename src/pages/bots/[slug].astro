---
import Layout from "@/layouts/Layout.astro";
import Cta from "@/components/Shared/Cta.astro";
import Breadcrumb from "@/components/Shared/Breadcrumb.astro";
import About from "@/components/Shared/About.astro";
import AIChat from "@/components/Shared/react/AIChat/AIChat.tsx";

const API_BASE = import.meta.env.PUBLIC_API_BASE

interface Bot {
    id: number;
    name: string;
    slug: string;
    description?: string;
    status?: string;
    brand_name?: string;
    phone?: string;
    social?: { vk?: string; telegram?: string };
    welcome_message?: string;
    actions?: string[];
    knowledge_count?: number;
}

// Получаем данные конкретного бота по slug через поиск ассистентов.
async function fetchBotBySlug(slug: string): Promise<Bot | null> {
    try {
        const url = `${API_BASE}/v1/assistants/search?filter%5Bslug%5D=${encodeURIComponent(slug)}`;
        const res = await fetch(url, { headers: { accept: "application/json" } });
        if (!res.ok) return null;
        const json = await res.json();
        const list: Bot[] = json.data || [];
        return list.find((b) => b.slug === slug) || list[0] || null;
    } catch (e) {
        console.error("Error fetching bot by slug:", slug, e);
        return null;
    }
}

export async function getStaticPaths() {
    // ВАЖНО: getStaticPaths выполняется в изолированном контексте и не видит
    // переменные верхнего уровня (например, API_BASE), поэтому база задаётся локально.
    const apiBase = import.meta.env.PUBLIC_API_BASE
    let chats: Bot[] = [];
    try {
        const res = await fetch(`${apiBase}/chats`, {
            headers: { accept: "application/json" }
        });
        if (res.ok) {
            const data = await res.json();
            chats = data.data || [];
        }
    } catch (e) {
        console.error("Error fetching chats for static paths:", e);
    }

    return chats
        .filter((chat) => chat.slug)
        .map((chat) => ({
            params: { slug: chat.slug },
            props: { bot: chat }
        }));
}

const { bot } = Astro.props as { bot: Bot };

// Дополнительно подтягиваем полные данные бота по slug (поиск по адресу /assistants/search).
const fresh = await fetchBotBySlug(bot.slug);
const data: Bot = fresh || bot;

const name = data.name;
const brand = data.brand_name || name;
const niche = data.description || "";

// SEO: Тайтл «Умный чат бот : {name} | BotSync» (суффикс « | BotSync» добавляет Layout).
const seoTitle = `Умный чат-бот ии ${name}: общаться с нейросетью`;
const seoDescription = niche
    ? `Умный чат бот ${name} от ${brand} — нейросеть на базе RAG, которая отвечает на вопросы онлайн 24/7. ${niche}. Пообщайтесь с ИИ-ассистентом ${name} прямо в браузере: чат бот ии онлайн без регистрации.`
    : `Умный чат бот ${name} — ИИ-ассистент на базе нейросети и RAG. Задайте вопрос и общайтесь с чат ботом ${name} онлайн: быстрые ответы 24/7, бесплатно и без регистрации.`;

const canonicalURL = new URL(`/bots/${data.slug}`, Astro.site || "https://botsync.ru");

const breadcrumbItems = [
    { name: "Главная", url: "/" },
    { name: "Каталог ботов", url: "/bots" },
    { name }
];

// JSON-LD: разговорное ИИ-приложение (чат бот / нейросеть).
const botSchema = {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": `${name} — умный чат бот`,
    "applicationCategory": "BusinessApplication",
    "operatingSystem": "Web",
    "url": canonicalURL.toString(),
    "description": seoDescription,
    "creator": {
        "@type": "Organization",
        "name": "BotSync",
        "url": "https://botsync.ru"
    },
    "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "RUB"
    }
};

const faqSchema = {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
        {
            "@type": "Question",
            "name": `Что умеет чат бот ${name}?`,
            "acceptedAnswer": {
                "@type": "Answer",
                "text": `${name} — это умный ИИ чат бот на базе нейросети и технологии RAG. Он отвечает на вопросы по теме «${niche || brand}», работает онлайн 24/7 и общается на естественном языке.`
            }
        },
        {
            "@type": "Question",
            "name": `Как пообщаться с нейросетью ${name} онлайн?`,
            "acceptedAnswer": {
                "@type": "Answer",
                "text": `Просто напишите сообщение в чат на этой странице. Чат бот ${name} ответит мгновенно — бесплатно и без регистрации.`
            }
        },
        {
            "@type": "Question",
            "name": "Можно ли создать такого же умного бота для своего бизнеса?",
            "acceptedAnswer": {
                "@type": "Answer",
                "text": "Да. BotSync позволяет создать ИИ чат бота с базой знаний (RAG), обучить его на ваших документах и внедрить на сайт за несколько минут."
            }
        }
    ]
};

// Вся информация о боте для переиспользуемого компонента About.
const aboutParagraphs = [
    `Хотите поговорить с искусственным интеллектом? Чат бот ${name} — это умный онлайн-собеседник на базе нейросети. Он понимает естественный язык, ведёт диалог и мгновенно отвечает на вопросы по теме «${niche || brand}». Никакой регистрации и установки приложений: общение с ботом доступно прямо на сайте.`,
    `В отличие от обычных скриптовых ботов, ${name} построен на технологии RAG (Retrieval-Augmented Generation). Это значит, что нейросеть отвечает не «из головы», а опирается на проверенную базу знаний — поэтому ответы ИИ чат бота точные и по делу.`
];

const aboutFeatures = [
    {
        title: "Чат бот онлайн 24/7",
        desc: `ИИ-ассистент ${name} на связи круглосуточно. Переписка с ботом идёт в режиме реального времени — задайте вопрос нейросети и получите ответ за секунды.`
    },
    {
        title: "Умные ответы на базе RAG",
        desc: `Нейросеть чат бот обучена на данных бренда ${brand}. Бот отвечает на вопросы, опираясь на актуальную базу знаний, а не на обобщённые данные из интернета.`
    },
    {
        title: "Живое общение с нейросетью",
        desc: `${name} общается как человек: понимает контекст переписки, уточняет детали и помогает решить ваш вопрос. Это удобный виртуальный собеседник для бизнеса и клиентов.`
    },
    {
        title: "Бесплатно и без регистрации",
        desc: `Пообщаться с ИИ можно бесплатно и без регистрации. Просто начните чат с ботом ${name} — никаких СМС и анкет не требуется.`
    }
];

const aboutContent = [
    {
        title: "Как пообщаться с ботом",
        desc: `Напишите сообщение в поле чата или выберите готовый вопрос — умный ИИ-ассистент ${name} обработает запрос с помощью нейросети и даст развёрнутый ответ онлайн.`
    },
    {
        title: "Свой бот для бизнеса",
        desc: "BotSync создаёт ИИ чат-ботов с базой знаний (RAG), обучает нейросеть на ваших документах и внедряет ассистента на сайт — автоматизация поддержки и продаж с помощью искусственного интеллекта."
    }
];
---

<Layout
    title={seoTitle}
    description={seoDescription}
    canonicalURL={canonicalURL}
    schema={[botSchema, faqSchema]}
>
    <Breadcrumb title={`Умный чат бот ${name}`} items={breadcrumbItems} />

    <!-- intro / описание бота start -->
    <section class="bot-intro pt-100 md-pt-80 pb-50 md-pb-40">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-lg-9 text-center">
                    <div class="section-title align-items-center">
                        <span class="sub-title">Живое общение с нейросетью</span>
                        <h2>Умный чат бот <span>{name}</span> онлайн</h2>
                        <p class="desc">
                            {name} — это ИИ чат бот на базе нейросети и технологии RAG.
                            {niche ? ` ${niche}.` : ""} Задайте вопрос и пообщайтесь с
                            искусственным интеллектом прямо в браузере — быстрые ответы 24/7,
                            бесплатно и без регистрации.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </section>
    <!-- intro / описание бота end -->

    <!-- AI chat start -->
    <AIChat
        client:load
        chatId={data.id}
        title={`${brand} — ИИ-ассистент`}
        subtitle={niche || "Онлайн-помощник на базе нейросети"}
        greeting={data.welcome_message || `Здравствуйте! Я — умный чат бот ${name}. Задайте мне любой вопрос.`}
    />
    <!-- AI chat end -->

    <!-- about bot / вся информация о боте start -->
    <About
        subTitle="Живое общение с нейросетью"
        title={`Умный чат бот`}
        titleAccent={name}
        paragraphs={aboutParagraphs}
        features={aboutFeatures}
        phone={data.phone}
        phoneLabel={`Связаться с ${brand}`}
        contentItems={aboutContent}
    />
    <!-- about bot / вся информация о боте end -->

    <Cta />
</Layout>
