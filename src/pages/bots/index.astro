---
import Cta from "@/components/Shared/Cta.astro";
import Layout from "@/layouts/Layout.astro";
import Breadcrumb from "@/components/Shared/Breadcrumb.astro";

interface Bot {
    id: number;
    name: string;
    slug: string;
    description?: string;
}

let chats: Bot[] = [];
try {
    const res = await fetch(`${import.meta.env.PUBLIC_API_BASE}/chats`, {
        headers: {
            "accept": "application/json"
        }
    });
    if (res.ok) {
        const data = await res.json();
        chats = data.data || [];
    }
} catch (e) {
    console.error("Error fetching chats:", e);
}

const breadcrumbItems = [
    { name: "Главная", url: "/" },
    { name: "Каталог ботов" }
];
---
<Layout
    title="Каталог умных чат ботов и ИИ-ассистентов"
    description="Каталог умных чат ботов BotSync на базе нейросети и RAG. Пообщайтесь с ИИ-ассистентами онлайн — боты отвечают на вопросы бесплатно и без регистрации."
>
    <Breadcrumb title="Каталог умных чат ботов" items={breadcrumbItems} />

    <!-- bots section start -->
    <section class="project-section-4 pt-100 md-pt-80 pb-70 md-pb-50">
        <div class="container">
            <div class="row">
                {chats.map((chat, index) => (
                    <div class="col-lg-6">
                        <div class="project-item right-after wow fadeInUp" data-wow-delay={`.${2 + (index % 5)}s`}>
                            <div class="project-image">
                                <figure>
                                    <img src={`assets/images/project/project-${(index % 6) + 1}.jpg`} alt={'умный чат бот ии: ' + chat.name} />
                                </figure>
                            </div>
                            <div class="project-content">
                                <h2><a href={`/bots/${chat.slug}`}>{chat.name}</a></h2>
                                <p>{chat.description}</p>
                                <div class="project-button-wapper">
                                    <a href={`/bots/${chat.slug}`} class="theme-button style-1" aria-label={`Пообщаться с ботом ${chat.name}`}>
                                        <span data-text="Пообщаться с ботом">Пообщаться с ботом</span>
                                        <i class="fa-solid fa-arrow-right"></i>
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                ))}
            </div>
        </div>
    </section>
    <!-- bots section end -->

    <Cta />
</Layout>
