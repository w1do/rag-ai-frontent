---
import Layout from "@/layouts/Layout.astro";

const pageTitle = "База знаний на RAG — умная система управления знаниями с ИИ | BotSync";
const pageDescription = "Создайте корпоративную базу знаний на базе технологий RAG и LLM. Обучите ИИ на своих документах, PDF и сайтах для мгновенного поиска и ответов на вопросы сотрудников и клиентов.";
---

<Layout title={pageTitle} description={pageDescription}>
	<!-- hero section start -->
	<section class="hero-section-3">
		<!-- bakground assets start -->
		<div class="bakground-assets">
			<img class="line-top" src="/assets/images/hero/bg-line-two.png" alt="hero line">
			<img class="shape-one" src="/assets/images/hero/light-shape-1.png" alt="hero light shape one">
			<img class="shape-two" src="/assets/images/hero/light-shape-2.png" alt="hero light shape two">
		</div>
		<!-- bakground assets end -->
		<div class="container">
			<div class="row">
				<div class="col-12">
					<!-- hero wapper start -->
					<div class="hero-wapper">
						<!-- hero content start -->
						<div class="hero-content">
							<div class="section-title align-items-center">
								<span class="sub-title">Интеллектуальная база знаний на RAG</span>
								<h1>Ваша корпоративная
									<span>база знаний</span>
									теперь на <span class="prompt">
                                                <svg class="circle1" width="8" height="8" viewBox="0 0 8 8" fill="none"
                                                     xmlns="http://www.w3.org/2000/svg">
                                                    <circle cx="4" cy="4" r="4" fill="currentColor"></circle>
                                                </svg>
                                                <svg class="circle2" width="8" height="8" viewBox="0 0 8 8" fill="none"
                                                     xmlns="http://www.w3.org/2000/svg">
                                                    <circle cx="4" cy="4" r="4" fill="currentColor"></circle>
                                                </svg>
                                                стеке RAG
                                                <svg class="circle3" width="8" height="8" viewBox="0 0 8 8" fill="none"
                                                     xmlns="http://www.w3.org/2000/svg">
                                                    <circle cx="4" cy="4" r="4" fill="currentColor"></circle>
                                                </svg>
                                                <svg class="circle4" width="8" height="8" viewBox="0 0 8 8" fill="none"
                                                     xmlns="http://www.w3.org/2000/svg">
                                                    <circle cx="4" cy="4" r="4" fill="currentColor"></circle>
                                                </svg>
                                            </span>
									<img src="/assets/images/hero/tag-image.png" alt="tag image">
								</h1>
								<p class="desc">Технология Retrieval Augmented Generation (RAG) превращает ваши статические документы в живую интерактивную систему. Загрузите PDF, ссылки на сайт или текстовые файлы, и получите умную базу знаний, которая отвечает на вопросы мгновенно и точно.</p>
							</div>

							<div class="hero-input-box">
								<form action="#" class="input-form" id="input-forms">
									<div class="hero-input-group">
                                                <textarea name="search" id="search"
                                                          placeholder="Загрузите документы и задайте вопрос по вашей базе знаний..."></textarea>
									</div>
									<div class="hero-input-buttons">
										<div class="hero-button-left">
											<div class="hero-plus">
												<a href="#" aria-label="plus"><i class="fa-solid fa-plus"></i></a>
											</div>
											<div class="hero-tool">
												<a href="#" aria-label="tools"><i class="fa-solid fa-sliders"></i> Настройки RAG</a>
											</div>
										</div>
										<div class="hero-button-right">
											<button type="submit" class="submit-btn" data-text="Поиск" aria-label="paper plane">
												<i class="fa-solid fa-paper-plane"></i>
											</button>
										</div>
									</div>
								</form>
							</div>

							<div class="hero-footer">
								<ul>
									<li>LLM RAG поиск</li>
									<li>Анализ PDF и DOCX</li>
									<li>Retrieval Augmented Generation</li>
									<li>Векторная база данных</li>
									<li>Semantic search</li>
									<li>Корпоративные данные</li>
								</ul>
							</div>

						</div>
						<!-- hero content end -->
					</div>
					<!-- hero wapper end -->
				</div>
			</div>
		</div>
