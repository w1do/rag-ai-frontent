---
import ServiceLayout from "@/layouts/ServiceLayout.astro";
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
    const possibilities = await getCollection('possibilities');
    return possibilities.map(possibility => ({
        params: { slug: possibility.id },
        props: { possibility },
    }));
}

const { possibility } = Astro.props;
const { Content } = await render(possibility);
const allPossibilities = await getCollection('possibilities');
const sortedPossibilities = allPossibilities.sort((a, b) => a.data.order - b.data.order);
---

<ServiceLayout service={possibility} sortedServices={sortedPossibilities}>
    <Content />
</ServiceLayout>