---
import Layout from "@/layouts/Layout.astro";
import Hero from "@/components/Shared/Hero.astro";
import Gallery from "@/components/Shared/Gallery.astro";
import Micon from "@/components/Shared/Micon.astro";
import ImageGenerator from "@/components/Shared/ImageGenerator.astro";
import Why from "@/components/Shared/Why.astro";
import Projects from "@/components/Shared/Projects.astro";
import MarqueeTicker from "@/components/Shared/MarqueeTicker.astro";
import HowIt from "@/components/Shared/HowIt.astro";
import Video from "@/components/Shared/Video.astro";
import Testimonials from "@/components/Shared/Testimonials.astro";
import Pricing from "@/components/Shared/Pricing.astro";
import Team from "@/components/Shared/Team.astro";
import Faq from "@/components/Shared/Faq.astro";
import Blog from "@/components/Shared/Blog.astro";

const seoData = {
    title: "Автоматизированные ответы на базе RAG и LLM",
    description: "Внедрите автоматизированные ответы с использованием RAG-технологий. ИИ-ассистент будет отвечать на вопросы клиентов на основе вашей базы знаний, снижая нагрузку на поддержку до 80%."
};

const miconItems = [
    { title: "Точность 100%", desc: "Использование RAG гарантирует, что ИИ не придумывает ответы, а берет их из вашей документации." },
    { title: "Экономия Времени", desc: "Автоматические ответы освобождают вашу поддержку от рутины, позволяя сфокусироваться на сложных кейсах." },
    { title: "Мгновенная Реакция", desc: "Клиенты получают ответы в ту же секунду, что значительно повышает их лояльность и конверсию." }
];

const imageGenItems = [
    {
        icon: "assets/images/image-generator/icon-1.png",
        title: "Анализ запроса",
        desc: "ИИ мгновенно определяет суть вопроса и соотносит его с доступными данными вашей компании."
    },
    {
        icon: "assets/images/image-generator/icon-2.png",
        title: "Поиск фактов",
        desc: "RAG-алгоритм находит конкретные параграфы в ваших документах, которые содержат ответ."
    },
    {
        icon: "assets/images/image-generator/icon-3.png",
        title: "Формирование ответа",
        desc: "LLM генерирует связный и вежливый ответ, используя только найденные факты, без искажений."
    }
];

const marqueeItems = [
    { text: "Автоответы RAG" },
    { text: "ИИ-автоматизация" },
    { text: "Точные ответы LLM" },
    { text: "Retrieval Augmented Generation" }
];

const faqItems = [
    {
        question: "Как обеспечить точность ответов?",
        answer: "Мы используем продвинутые RAG-алгоритмы, которые ограничивают область поиска ИИ только вашими доверенными документами. Если ответа нет в базе знаний, бот честно скажет об этом."
    },
    {
        question: "Можно ли подключить автоответы к Telegram или WhatsApp?",
        answer: "Да, наша платформа поддерживает интеграцию со всеми популярными мессенджерами через API или готовые коннекторы."
    }
];
---

<Layout title={seoData.title} description={seoData.description}>
    <Hero 
        subTitle="Автоматизация ответов с RAG"
        title="Умные"
        titleAccent="автоответы"
        titleMinutes="на базе RAG"
        desc="Автоматизированные ответы RAG позволяют ИИ генерировать точные сообщения, основываясь только на проверенных данных вашей компании. Забудьте о галлюцинациях ИИ."
    />
    <Gallery />
    <Micon items={miconItems} />
    <ImageGenerator 
        titlePre="Как работают "
        titleAccent="умные автоответы"
        titlePost="?"
        items={imageGenItems}
    />
    <Why 
        subTitle="Эффективность ИИ"
        titlePre="Почему стоит выбрать "
        titleAccent="автоответы RAG"
        titlePost="?"
    />
    <Projects 
        titlePre="Где нужны "
        titleAccent="автоматизированные ответы"
        titlePost="?"
    />
    <MarqueeTicker items={marqueeItems} />
    <HowIt 
        titlePre="Как работают "
        titleAccent="автоответы"
        titlePost=""
    />
    <Video />
    <Testimonials />
    <Pricing />
    <Team 
        titlePre="Эксперты по "
        titleAccent="автоматизации"
    />
    <Faq items={faqItems} />
    <Blog 
        subTitle="Блог об автоматизации"
        titlePre="Советы по "
        titleAccent="умным ответам"
        titlePost=""
    />
</Layout>
