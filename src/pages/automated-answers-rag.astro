---
import Layout from "@/layouts/Layout.astro";

const pageTitle = "Автоматизированные ответы на базе RAG и LLM | BotSync";
const pageDescription = "Внедрите автоматизированные ответы с использованием RAG-технологий. ИИ-ассистент будет отвечать на вопросы клиентов на основе вашей базы знаний, снижая нагрузку на поддержку до 80%.";
---

<Layout title={pageTitle} description={pageDescription}>
	<!-- hero section start -->
	<section class="hero-section-3">
		<!-- bakground assets start -->
		<div class="bakground-assets">
			<img class="line-top" src="/assets/images/hero/bg-line-two.png" alt="hero line">
			<img class="shape-one" src="/assets/images/hero/light-shape-1.png" alt="hero light shape one">
			<img class="shape-two" src="/assets/images/hero/light-shape-2.png" alt="hero light shape two">
		</div>
		<!-- bakground assets end -->
		<div class="container">
			<div class="row">
				<div class="col-12">
					<!-- hero wapper start -->
					<div class="hero-wapper">
						<!-- hero content start -->
						<div class="hero-content">
							<div class="section-title align-items-center">
								<span class="sub-title">Автоматизация ответов с RAG</span>
								<h1>Умные
									<span>автоответы</span>
									на базе <span class="prompt">
                                                <svg class="circle1" width="8" height="8" viewBox="0 0 8 8" fill="none"
                                                     xmlns="http://www.w3.org/2000/svg">
                                                    <circle cx="4" cy="4" r="4" fill="currentColor"></circle>
                                                </svg>
                                                <svg class="circle2" width="8" height="8" viewBox="0 0 8 8" fill="none"
                                                     xmlns="http://www.w3.org/2000/svg">
                                                    <circle cx="4" cy="4" r="4" fill="currentColor"></circle>
                                                </svg>
                                                технологий RAG
                                                <svg class="circle3" width="8" height="8" viewBox="0 0 8 8" fill="none"
                                                     xmlns="http://www.w3.org/2000/svg">
                                                    <circle cx="4" cy="4" r="4" fill="currentColor"></circle>
                                                </svg>
                                                <svg class="circle4" width="8" height="8" viewBox="0 0 8 8" fill="none"
                                                     xmlns="http://www.w3.org/2000/svg">
                                                    <circle cx="4" cy="4" r="4" fill="currentColor"></circle>
                                                </svg>
                                            </span>
									<img src="/assets/images/hero/tag-image.png" alt="tag image">
								</h1>
								<p class="desc">Автоматизированные ответы RAG позволяют ИИ генерировать точные сообщения, основываясь только на проверенных данных вашей компании. Забудьте о галлюцинациях ИИ — теперь каждый ответ подкреплен информацией из вашей базы знаний.</p>
							</div>

							<div class="hero-input-box">
								<form action="#" class="input-form" id="input-forms">
									<div class="hero-input-group">
                                                <textarea name="search" id="search"
                                                          placeholder="Введите пример вопроса клиента для теста автоответа..."></textarea>
									</div>
									<div class="hero-input-buttons">
										<div class="hero-button-left">
											<div class="hero-plus">
												<a href="#" aria-label="plus"><i class="fa-solid fa-plus"></i></a>
											</div>
											<div class="hero-tool">
												<a href="#" aria-label="tools"><i class="fa-solid fa-sliders"></i> Тюнинг ответов</a>
											</div>
										</div>
										<div class="hero-button-right">
											<button type="submit" class="submit-btn" data-text="Тест" aria-label="paper plane">
												<i class="fa-solid fa-paper-plane"></i>
											</button>
										</div>
									</div>
								</form>
							</div>

							<div class="hero-footer">
								<ul>
									<li>RAG AI ответы</li>
									<li>Автоматизация поддержки</li>
									<li>Точность LLM</li>
									<li>Контекстный поиск</li>
									<li>Интеграция с CRM</li>
									<li>Мгновенный отклик</li>
								</ul>
							</div>

						</div>
