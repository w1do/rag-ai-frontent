---
import Layout from "@/layouts/Layout.astro";
import Hero from "@/components/Shared/Hero.astro";
import Gallery from "@/components/Shared/Gallery.astro";
import Micon from "@/components/Shared/Micon.astro";
import ImageGenerator from "@/components/Shared/ImageGenerator.astro";
import Why from "@/components/Shared/Why.astro";
import Projects from "@/components/Shared/Projects.astro";
import MarqueeTicker from "@/components/Shared/MarqueeTicker.astro";
import HowIt from "@/components/Shared/HowIt.astro";
import Video from "@/components/Shared/Video.astro";
import Testimonials from "@/components/Shared/Testimonials.astro";
import Pricing from "@/components/Shared/Pricing.astro";
import Team from "@/components/Shared/Team.astro";
import Faq from "@/components/Shared/Faq.astro";
import Blog from "@/components/Shared/Blog.astro";

const seoData = {
    title: "Внедрение чат бота на сайт — профессиональная ИИ-интеграция | BotSync",
    description: "Узнайте, как выполнить быстрое внедрение чат бота на сайт. Мы предлагаем готовые виджеты и API интеграции для подключения умных ИИ-ассистентов с поддержкой RAG к любой CMS."
};

const miconItems = [
    { title: "Готовый Виджет", desc: "Просто вставьте одну строку кода в ваш HTML. Работает на WordPress, Tilda, Bitrix и др." },
    { title: "Мощный API", desc: "Используйте REST API для глубокой интеграции бота в ваше мобильное приложение или CRM." },
    { title: "Webhooks События", desc: "Получайте уведомления о новых лидах и диалогах в вашу систему управления в реальном времени." }
];

const imageGenItems = [
    {
        icon: "assets/images/image-generator/icon-1.png",
        title: "Выбор метода",
        desc: "Определитесь между быстрым виджетом или кастомной интеграцией через API под ваш проект."
    },
    {
        icon: "assets/images/image-generator/icon-2.png",
        title: "Настройка дизайна",
        desc: "Приведите внешний вид чата в соответствие с вашим брендбуком: цвета, иконки и шрифты."
    },
    {
        icon: "assets/images/image-generator/icon-3.png",
        title: "Публикация",
        desc: "Активируйте ИИ-бота на сайте и начните повышать конверсию в автоматическом режиме 24/7."
    }
];

const marqueeItems = [
    { text: "Внедрение на сайт" },
    { text: "API Интеграция" },
    { text: "ИИ Виджет" },
    { text: "Custom AI Solution" }
];

const faqItems = [
    {
        question: "На какие платформы можно установить виджет?",
        answer: "BotSync совместим с любой CMS (WordPress, Bitrix, Shopify, Tilda, Wix). Достаточно добавить JS-скрипт."
    },
    {
        question: "Будет ли виджет замедлять работу моего сайта?",
        answer: "Нет, наш виджет загружается асинхронно и оптимизирован для минимального влияния на скорость загрузки."
    }
];
---

<Layout title={seoData.title} description={seoData.description}>
    <Hero 
        subTitle="Профессиональное внедрение чат бота"
        title="Простое"
        titleAccent="внедрение на сайт"
        titleMinutes="за 5 минут"
        desc="Внедрение чат бота на сайт еще никогда не было таким простым. Просто скопируйте код виджета или используйте наше API. Поддержка всех популярных CMS."
    />
    <Gallery />
    <Micon items={miconItems} />
    <ImageGenerator 
        titlePre="Как выполнить "
        titleAccent="внедрение чат бота"
        titlePost="?"
        items={imageGenItems}
    />
    <Why 
        subTitle="Преимущества интеграции"
        titlePre="Почему стоит выбрать "
        titleAccent="наше внедрение"
        titlePost="?"
    />
    <Projects 
        titlePre="Где можно "
        titleAccent="установить чат бота"
        titlePost="?"
    />
    <MarqueeTicker items={marqueeItems} />
    <HowIt 
        titlePre="Как происходит "
        titleAccent="внедрение"
        titlePost="?"
    />
    <Video />
    <Testimonials />
    <Pricing />
    <Team 
        titlePre="Эксперты по "
        titleAccent="интеграции"
    />
    <Faq items={faqItems} />
    <Blog 
        subTitle="Блог об интеграциях"
        titlePre="Советы по "
        titleAccent="внедрению ИИ"
        titlePost=""
    />
</Layout>
