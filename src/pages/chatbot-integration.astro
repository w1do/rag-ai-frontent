---
import Layout from "@/layouts/Layout.astro";

const pageTitle = "Внедрение чат бота на сайт — профессиональная ИИ-интеграция | BotSync";
const pageDescription = "Узнайте, как выполнить быстрое внедрение чат бота на сайт. Мы предлагаем готовые виджеты и API интеграции для подключения умных ИИ-ассистентов с поддержкой RAG к любой CMS.";
