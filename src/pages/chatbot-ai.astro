                                                <textarea name="search" id="search"
                                                          placeholder="Пообщайтесь с ИИ-ботом или опишите, какой чат-бот вам нужен..."></textarea>
									</div>
									<div class="hero-input-buttons">
										<div class="hero-button-left">
											<div class="hero-plus">
												<a href="#" aria-label="plus"><i class="fa-solid fa-plus"></i></a>
											</div>
											<div class="hero-tool">
												<a href="#" aria-label="tools"><i class="fa-solid fa-sliders"></i> Выбрать нейросеть</a>
											</div>
										</div>
										<div class="hero-button-right">
											<button type="submit" class="submit-btn" data-text="Чат" aria-label="paper plane">
												<i class="fa-solid fa-paper-plane"></i>
											</button>
										</div>
									</div>
