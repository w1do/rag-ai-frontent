---
import Layout from "@/layouts/Layout.astro";

const pageTitle = "Чат бот с ИИ онлайн — умный нейросетевой помощник для бизнеса | BotSync";
const pageDescription = "Используйте современный чат бот с ИИ для общения с клиентами. Нейросеть чат бот на базе GPT и RAG обеспечит интеллектуальные ответы 24/7. Внедрение ИИ чат бота на любой сайт.";
---

<Layout title={pageTitle} description={pageDescription}>
	<!-- hero section start -->
	<section class="hero-section-3">
		<!-- bakground assets start -->
		<div class="bakground-assets">
			<img class="line-top" src="/assets/images/hero/bg-line-two.png" alt="hero line">
			<img class="shape-one" src="/assets/images/hero/light-shape-1.png" alt="hero light shape one">
			<img class="shape-two" src="/assets/images/hero/light-shape-2.png" alt="hero light shape two">
		</div>
		<!-- bakground assets end -->
		<div class="container">
			<div class="row">
				<div class="col-12">
					<!-- hero wapper start -->
					<div class="hero-wapper">
						<!-- hero content start -->
						<div class="hero-content">
							<div class="section-title align-items-center">
								<span class="sub-title">Умный чат бот с ИИ онлайн</span>
								<h1>Ваш персональный
									<span>ИИ чат бот</span>
