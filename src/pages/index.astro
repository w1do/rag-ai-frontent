---
import Layout from "@/layouts/Layout.astro";
import Hero from "@/components/Shared/Hero.astro";
import Gallery from "@/components/Shared/Gallery.astro";
import Micon from "@/components/Shared/Micon.astro";
import ImageGenerator from "@/components/Shared/ImageGenerator.astro";
import Why from "@/components/Shared/Why.astro";
import Projects from "@/components/Shared/Projects.astro";
import MarqueeTicker from "@/components/Shared/MarqueeTicker.astro";
import HowIt from "@/components/Shared/HowIt.astro";
import Video from "@/components/Shared/Video.astro";
import Testimonials from "@/components/Shared/Testimonials.astro";
import Pricing from "@/components/Shared/Pricing.astro";
import Team from "@/components/Shared/Team.astro";
import Faq from "@/components/Shared/Faq.astro";
import Blog from "@/components/Shared/Blog.astro";

const seoData = {
    title: "BotSync — Конструктор ИИ-ботов и RAG-платформа для бизнеса",
    description: "Создайте умного ИИ-агента за 5 минут. Обучение на ваших данных (PDF, сайты, Wiki) с помощью технологии RAG. Автоматизация поддержки и продаж.",
    ogImage: "/assets/images/og-main.png"
};

const mainSchema = {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "BotSync",
    "url": "https://botsync.ru",
    "potentialAction": {
        "@type": "SearchAction",
        "target": "https://botsync.ru/search?q={search_term_string}",
        "query-input": "required name=search_term_string"
    }
};

const miconItems = [
    { title: "ИИ-агенты для бизнеса", desc: "Автоматизируйте общение с клиентами с помощью умных чат-ботов на базе LLM." },
    { title: "RAG База знаний", desc: "Ваш бот обучается на ваших документах и отвечает только достоверной информацией." },
    { title: "Мультиплатформенность", desc: "Интеграция виджета на сайт, в Telegram или подключение через API." }
];

const imageGenItems = [
    {
        icon: "assets/images/image-generator/icon-1.png",
        title: "Конструктор ИИ-ботов",
        desc: "Простой интерфейс для создания и настройки интеллектуальных ассистентов без программирования."
    },
    {
        icon: "assets/images/image-generator/icon-2.png",
        title: "Обработка PDF и сайтов",
        desc: "Загрузите документы или укажите URL, и ваш ИИ-бот мгновенно изучит всю информацию."
    },
    {
        icon: "assets/images/image-generator/icon-3.png",
        title: "Голосовые RAG-системы",
        desc: "Поддержка голосовых сообщений и интеграция с телефонией для полноценного ИИ-колл-центра."
    }
];

const marqueeItems = [
    { text: "ИИ-Бот" },
    { text: "RAG Система" },
    { text: "Конструктор Чат-ботов" },
    { text: "LLM Обучение" },
    { text: "Искусственный Интеллект" },
    { text: "База Знаний" }
];

console.log(import.meta.env.PUBLIC_API_BASE)
---

<Layout title={seoData.title} description={seoData.description} ogImage={seoData.ogImage} schema={mainSchema}>
    <Hero 
        subTitle="Интеллектуальная автоматизация вашего бизнеса"
        title="Создайте своего"
        titleAccent="ИИ-помощника"
        titleMinutes="за 5 минут"
        desc="BotSync — профессиональная RAG-платформа. Мы помогаем компаниям внедрять искусственный интеллект для обработки документов и автоматизации диалогов. Чат-бот ИИ с доступом к вашим данным."
    />
    <Gallery/>
    <Micon items={miconItems}/>
    <ImageGenerator 
        titlePre="Возможности "
        titleAccent="BotSync"
        titlePost=" для вашего роста"
        items={imageGenItems}
    />
    <Why 
        subTitle="Почему выбирают нас"
        titlePre="Преимущества "
        titleAccent="ИИ-автоматизации"
        titlePost=""
    />
    <Projects 
        titlePre="Наши "
        titleAccent="Кейсы"
        titlePost=" внедрения"
    />
    <MarqueeTicker items={marqueeItems}/>
    <HowIt 
        titlePre="Как запустить "
        titleAccent="ИИ-бота"
        titlePost=" сегодня"
    />
    <Video />
    <Testimonials />
    <Pricing />
    <Team 
        titlePre="Команда "
        titleAccent="BotSync"
    />
    <Faq />
    <Blog 
        subTitle="Мир ИИ и RAG"
        titlePre="Полезные "
        titleAccent="Материалы"
        titlePost=""
    />
</Layout>
