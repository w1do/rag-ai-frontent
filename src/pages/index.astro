---
import Layout from "@/layouts/Layout.astro";
---

<Layout>
	<!-- hero section start -->
	<section class="hero-section-3">
		<!-- bakground assets start -->
		<div class="bakground-assets">
			<img class="line-top" src="assets/images/hero/bg-line-two.png" alt="hero line">
			<img class="shape-one" src="assets/images/hero/light-shape-1.png" alt="hero light shape one">
			<img class="shape-two" src="assets/images/hero/light-shape-2.png" alt="hero light shape two">
		</div>
		<!-- bakground assets end -->
		<div class="container">
			<div class="row">
				<div class="col-12">
					<!-- hero wapper start -->
					<div class="hero-wapper">
						<!-- hero content start -->
						<div class="hero-content">
							<div class="section-title align-items-center">
								<span class="sub-title">ИИ-автоматизация для масштабируемого бизнеса</span>
								<h1>Создайте умного
									<span>ИИ-агента</span>
									за 5 <span class="prompt">
                                                <svg class="circle1" width="8" height="8" viewBox="0 0 8 8" fill="none"
                                                     xmlns="http://www.w3.org/2000/svg">
                                                    <circle cx="4" cy="4" r="4" fill="currentColor"></circle>
                                                </svg>
                                                <svg class="circle2" width="8" height="8" viewBox="0 0 8 8" fill="none"
                                                     xmlns="http://www.w3.org/2000/svg">
                                                    <circle cx="4" cy="4" r="4" fill="currentColor"></circle>
                                                </svg>
                                                минут
                                                <svg class="circle3" width="8" height="8" viewBox="0 0 8 8" fill="none"
                                                     xmlns="http://www.w3.org/2000/svg">
                                                    <circle cx="4" cy="4" r="4" fill="currentColor"></circle>
                                                </svg>
                                                <svg class="circle4" width="8" height="8" viewBox="0 0 8 8" fill="none"
                                                     xmlns="http://www.w3.org/2000/svg">
                                                    <circle cx="4" cy="4" r="4" fill="currentColor"></circle>
                                                </svg>
                                            </span>
									<img src="assets/images/hero/tag-image.png" alt="tag image">
								</h1>
								<p class="desc">BotSync — лучшая RAG-платформа для бизнеса. Наш конструктор ИИ-ботов позволяет обучить ассистента на ваших документах, базе знаний и сайте мгновенно. Автоматизируйте поддержку и продажи с помощью передовых технологий LLM.</p>
							</div>

							<div class="hero-input-box">
								<form action="#" class="input-form" id="input-forms">
									<div class="hero-input-group">
                                                <textarea name="search" id="search"
                                                          placeholder="Опишите, какую задачу должен решать ваш ИИ-бот..."></textarea>
									</div>
									<div class="hero-input-buttons">
										<div class="hero-button-left">
											<div class="hero-plus">
												<a href="#" aria-label="plus"><i class="fa-solid fa-plus"></i></a>
											</div>
											<div class="hero-tool">
												<a href="#" aria-label="tools"><i class="fa-solid fa-sliders"></i> Настройки</a>
											</div>
										</div>
										<div class="hero-button-right">
											<button type="submit" class="submit-btn" data-text="Создать" aria-label="paper plane">
												<i class="fa-solid fa-paper-plane"></i>
											</button>
										</div>
									</div>
								</form>
							</div>

							<div class="hero-footer">
								<ul>
									<li>Обучение на PDF</li>
									<li>Парсинг сайтов</li>
									<li>Голосовые RAG</li>
									<li>Интеграция по API</li>
									<li>Виджет на сайт</li>
									<li>JSON данные</li>
								</ul>
							</div>

						</div>
						<!-- hero content end -->
					</div>
					<!-- hero wapper end -->
				</div>
			</div>
		</div>
	</section>
	<!-- hero section end -->

	<!-- image section start -->
	<div class="image-section">
		<!-- bakground assets start -->
		<div class="bakground-assets">
			<img class="shape-one" src="assets/images/image/shape-top.png" alt="shape top">
			<img class="shape-two" src="assets/images/image/shape-bottom.png" alt="shape bottom">
		</div>
		<!-- bakground assets end -->
		<div class="container-fluid">
			<div class="row">
				<div class="col-lg-12">
					<!-- image wapper start -->
					<div class="image-wapper">
						<!-- image box start -->
						<div class="image-box">
							<!-- image item start -->
							<div class="image-item">
								<figure>
									<img src="assets/images/image/image-1.jpg" alt="image one">
								</figure>
							</div>
							<!-- image item end -->
							<!-- image item start -->
							<div class="image-item">
								<figure>
									<img src="assets/images/image/image-2.jpg" alt="image two">
								</figure>
							</div>
							<!-- image item end -->
							<!-- image item start -->
							<div class="image-item">
								<figure>
									<img src="assets/images/image/image-3.jpg" alt="image three">
								</figure>
							</div>
							<!-- image item end -->
							<!-- image item start -->
							<div class="image-item">
								<figure>
									<img src="assets/images/image/image-4.jpg" alt="image four">
								</figure>
							</div>
							<!-- image item end -->
							<!-- image item start -->
							<div class="image-item">
								<figure>
									<img src="assets/images/image/image-5.jpg" alt="image five">
								</figure>
							</div>
							<!-- image item start -->
						</div>
						<!-- image box end -->
						<!-- image box start -->
						<div class="image-box">
							<!-- image item start -->
							<div class="image-item">
								<figure>
									<img src="assets/images/image/image-1.jpg" alt="image one">
								</figure>
							</div>
							<!-- image item end -->
							<!-- image item start -->
							<div class="image-item">
								<figure>
									<img src="assets/images/image/image-2.jpg" alt="image two">
								</figure>
							</div>
							<!-- image item end -->
							<!-- image item start -->
							<div class="image-item">
								<figure>
									<img src="assets/images/image/image-3.jpg" alt="image three">
								</figure>
							</div>
							<!-- image item end -->
							<!-- image item start -->
							<div class="image-item">
								<figure>
									<img src="assets/images/image/image-4.jpg" alt="image four">
								</figure>
							</div>
							<!-- image item end -->
							<!-- image item start -->
							<div class="image-item">
								<figure>
									<img src="assets/images/image/image-5.jpg" alt="image five">
								</figure>
							</div>
							<!-- image item end -->
						</div>
						<!-- image box end -->
					</div>
					<!-- image wapper end -->
				</div>
			</div>
		</div>
	</div>
	<!-- image section end -->

	<!-- micon section start -->
	<section class="micon-section pt-100 md-pt-80">
		<div class="container">
			<div class="row">
				<div class="col-lg-12">
					<!-- micon wapper start -->
					<div class="micon-wapper">
						<!-- micon items start -->
						<div class="micon-items right-after wow fadeInUp" data-wow-delay=".3s">
							<div class="micon-content">
								<h2>Быстрое <br> Обучение</h2>
								<p>Загрузите документы, и ваш ИИ-агент будет готов к работе уже через несколько минут.</p>
							</div>
						</div>
						<!-- micon items end -->
						<!-- micon items start -->
						<div class="micon-items right-after wow fadeInUp" data-wow-delay=".4s">
							<div class="micon-content">
								<h2>Точные <br> Ответы</h2>
								<p>Технология RAG гарантирует, что ИИ использует только проверенную информацию из вашей базы знаний.</p>
							</div>
						</div>
						<!-- micon items end -->
						<!-- micon items start -->
						<div class="micon-items right-after wow fadeInUp" data-wow-delay=".5s">
							<div class="micon-content">
								<h2>Гибкие <br> Настройки</h2>
								<p>Настройте тон общения, роль и поведение ИИ под специфику вашего бизнеса и бренда.</p>
							</div>
						</div>
						<!-- micon items end -->
					</div>
					<!-- micon wapper end -->
				</div>
			</div>
		</div>
	</section>
	<!-- micon section end -->

	<!-- image generator section start -->
	<section class="image-generator-section pt-100 md-pt-80 pb-100 md-pb-80">
		<div class="container">
			<div class="row">
				<div class="col-lg-12">
					<!-- section title start -->
					<div class="section-title text-center wow fadeInUp" data-wow-delay=".2s">
						<span class="sub-title">Возможности платформы</span>
						<h2>Что такое <span>RAG-агент</span> BotSync?</h2>
					</div>
					<!-- section title end -->
				</div>
			</div>
			<div class="row">
				<div class="col-lg-12">
					<div class="image-generator-wapper">
						<!-- image-generator items start -->
						<div class="image-generator-items right-after wow fadeInUp" data-wow-delay=".3s">
							<div class="image-generator-icon">
								<figure>
									<img src="assets/images/image-generator/icon-1.png" alt="generator one">
								</figure>
							</div>
							<div class="image-generator-content">
								<h2>Интеллектуальная база знаний</h2>
								<p>Ваш чат-бот мгновенно извлекает информацию из PDF, Excel, JSON и текстовых файлов, предоставляя точные ответы клиентам 24/7 без галлюцинаций.</p>
							</div>
						</div>
						<!-- image-generator items end -->
						<!-- image-generator items start -->
						<div class="image-generator-items right-after wow fadeInUp" data-wow-delay=".4s">
							<div class="image-generator-icon">
								<figure>
									<img src="assets/images/image-generator/icon-2.png" alt="generator two">
								</figure>
							</div>
							<div class="image-generator-content">
								<h2>От данных <br> к диалогу</h2>
								<p>Просто загрузите ссылку на ваш сайт или файл. Наша система автоматически проиндексирует данные и создаст экспертного консультанта для вашего бизнеса.</p>
							</div>
						</div>
						<!-- image-generator items end -->
						<!-- image-generator items start -->
						<div class="image-generator-items right-after wow fadeInUp" data-wow-delay=".5s">
							<div class="image-generator-icon">
								<figure>
									<img src="assets/images/image-generator/icon-3.png" alt="generator three">
								</figure>
							</div>
							<div class="image-generator-content">
								<h2>Создано для бизнеса и команд</h2>
								<p>BotSync легко интегрируется в CRM, мессенджеры и сайты. Это идеальное решение для отделов продаж, техподдержки и HR-департаментов.</p>
							</div>
						</div>
						<!-- image-generator items end -->
					</div>
				</div>
			</div>
			<div class="row">
				<div class="col-lg-12">
					<!-- image generator footer start -->
					<div class="image-generator-footer mt-30 wow fadeInUp" data-wow-delay=".6s">
						<div class="image-generator-button text-center">
							<a href="#contact" class="theme-button style-1" aria-label="Начать бесплатно">
								<span data-text="Начать бесплатно">Начать бесплатно</span>
								<i class="fa-solid fa-arrow-right"></i>
							</a>
						</div>
					</div>
					<!-- image generator footer end -->
				</div>
			</div>
		</div>
	</section>
	<!-- image generator section end -->

	<!-- why section start -->
	<section class="why-section mlr">
		<!-- why wapper start -->
		<div class="why-wapper pt-100 md-pt-80 pb-100 md-pb-80">
			<div class="bakground-assets">
				<img class="shape-four" src="assets/images/hero/hero-2-shape-4.png" alt="hero shape four">
			</div>
			<div class="container">
				<div class="row">
					<div class="col-lg-4">
						<!-- section title start -->
						<div class="section-title wow fadeInUp" data-wow-delay=".2s">
							<span class="sub-title">Почему BotSync</span>
							<h2>Почему стоит выбрать нашу <span>RAG-платформу</span>?</h2>
						</div>
						<!-- section title end -->
					</div>
					<div class="col-lg-8">
						<div class="why-box">
							<!-- why items start -->
							<div class="why-items right-after wow fadeInUp" data-wow-delay=".3s">
								<div class="why-icon">
									<figure>
										<img src="assets/images/why/icon-1.png" alt="why one">
									</figure>
								</div>
								<div class="why-content">
									<h2>Экономия времени</h2>
									<p>Автоматизируйте до 80% рутинных запросов клиентов, освобождая сотрудников для решения действительно сложных и творческих задач.</p>
								</div>
							</div>
							<!-- why items end -->
							<!-- why items start -->
							<div class="why-items right-after wow fadeInUp" data-wow-delay=".4s">
								<div class="why-icon">
									<figure>
										<img src="assets/images/why/icon-2.png" alt="why two">
									</figure>
								</div>
								<div class="why-content">
									<h2>Мультимодальность</h2>
									<p>Наш ИИ понимает не только текст, но и голосовые сообщения, а также умеет работать со сложными структурами данных и таблицами.</p>
								</div>
							</div>
							<!-- why items end -->
							<!-- why items start -->
							<div class="why-items right-after wow fadeInUp" data-wow-delay=".5s">
								<div class="why-icon">
									<figure>
										<img src="assets/images/why/icon-3.png" alt="why three">
									</figure>
								</div>
								<div class="why-content">
									<h2>Безопасность данных</h2>
									<p>Ваша интеллектуальная собственность остается под защитой. Мы обеспечиваем конфиденциальность данных при обучении ваших локальных моделей.</p>
								</div>
							</div>
							<!-- why items end -->
							<!-- why items start -->
							<div class="why-items right-after wow fadeInUp" data-wow-delay=".6s">
								<div class="why-icon">
									<figure>
										<img src="assets/images/why/icon-4.png" alt="why four">
									</figure>
								</div>
								<div class="why-content">
									<h2>Легкая интеграция</h2>
									<p>Установите готовый виджет на сайт за одну минуту или используйте наше мощное API для глубокой интеграции в ваши рабочие процессы.</p>
								</div>
							</div>
							<!-- why items end -->
						</div>
					</div>
				</div>
			</div>
		</div>
		<!-- why wapper end -->
	</section>
	<!-- why section end -->

	<!-- project section start -->
	<section class="project-section-3 pt-100 md-pt-80 pb-100 md-pb-80">
		<div class="container">
			<div class="row">
				<div class="col-lg-12">
					<!-- section title start -->
					<div class="section-title text-center wow fadeInUp" data-wow-delay=".2s">
						<span class="sub-title">Наши кейсы</span>
						<h2>Где можно использовать <span>RAG-системы</span>?</h2>
					</div>
					<!-- section title end -->
				</div>
			</div>
			<div class="row">
				<div class="col-lg-12">
					<!-- project wapper start -->
					<div class="project-wapper grid-1">
						<!-- project item start -->
						<div class="project-item sticky">
							<div class="project-image order-lg-2">
								<a href="project-details.html">
									<figure class="image-anime">
										<img src="assets/images/project/project-3-1.jpg" alt="project image one">
									</figure>
								</a>
							</div>
							<div class="project-content">
								<h2><a href="#">Техническая поддержка и Helpdesk</a></h2>
								<p class="desc">Автоматизируйте ответы на часто задаваемые вопросы, используя вашу базу знаний. ИИ-агент мгновенно найдет нужное решение в инструкциях и поможет клиенту.</p>
								<div class="check-list mb-30">
									<ul>
										<li>Снижение нагрузки на операторов до 70%</li>
										<li>Мгновенные ответы 24/7 на любом языке</li>
										<li>Точное следование техническим регламентам</li>
										<li>Автоматическая классификация обращений</li>
									</ul>
								</div>
								<div class="project-button">
									<a href="#contact" class="theme-button style-1" aria-label="Подробнее">
										<span data-text="Подробнее">Подробнее</span>
										<i class="fa-solid fa-arrow-right"></i>
									</a>
								</div>
							</div>
						</div>
						<!-- project item end -->
						<!-- project item start -->
						<div class="project-item sticky">
							<div class="project-image order-lg-2">
								<a href="project-details.html">
									<figure class="image-anime">
										<img src="assets/images/project/project-3-2.jpg" alt="project image two">
									</figure>
								</a>
							</div>
							<div class="project-content">
								<h2><a href="#">Отдел продаж и Лидогенерация</a></h2>
								<p class="desc">ИИ-агент квалифицирует лидов, отвечает на вопросы о продукте и помогает выбрать подходящий тариф, основываясь на данных о ваших услугах.</p>
								<div class="check-list mb-30">
									<ul>
										<li>Увеличение конверсии за счет скорости ответа</li>
										<li>Автоматический сбор контактных данных</li>
										<li>Персонализированные рекомендации товаров</li>
										<li>Интеграция с вашей CRM-системой</li>
									</ul>
								</div>
								<div class="project-button">
									<a href="#contact" class="theme-button style-1" aria-label="Подробнее">
										<span data-text="Подробнее">Подробнее</span>
										<i class="fa-solid fa-arrow-right"></i>
									</a>
								</div>
							</div>
						</div>
						<!-- project item end -->
						<!-- project item start -->
						<div class="project-item sticky">
							<div class="project-image order-lg-2">
								<a href="project-details.html">
									<figure class="image-anime">
										<img src="assets/images/project/project-3-3.jpg" alt="project image three">
									</figure>
								</a>
							</div>
							<div class="project-content">
								<h2><a href="#">Корпоративное обучение и HR</a></h2>
								<p class="desc">Создайте внутреннего ассистента для сотрудников. ИИ поможет быстро найти информацию по внутренним регламентам, FAQ и обучающим материалам.</p>
								<div class="check-list mb-30">
									<ul>
										<li>Быстрый онбординг новых сотрудников</li>
										<li>Доступ к базе знаний компании в один клик</li>
										<li>Снижение нагрузки на HR-департамент</li>
										<li>Обучение на внутренних регламентах и Wiki</li>
									</ul>
								</div>
								<div class="project-button">
									<a href="#contact" class="theme-button style-1" aria-label="Подробнее">
										<span data-text="Подробнее">Подробнее</span>
										<i class="fa-solid fa-arrow-right"></i>
									</a>
								</div>
							</div>
						</div>
						<!-- project item end -->
					</div>
					<!-- project wapper end -->
				</div>
			</div>
			<div class="row">
				<div class="col-lg-12">
					<!-- project start -->
					<div class="project-footer">
						<p>Мы помогаем бизнесу проектировать, создавать и внедрять интеллектуальные решения, которые приносят реальные результаты. <a href="#contact">Узнать больше</a></p>
					</div>
					<!-- more event content end -->
				</div>
			</div>
		</div>
	</section>
	<!-- project section end -->

	<!-- marquee ticker section start -->
	<div class="marquee-ticker-section">
		<div class="marquee-ticker-box">
			<div class="marquee-content">
				<div class="marquee-icon">
					<img src="assets/images/icon/marquee.png" alt="marquee image one">
				</div>
				<p data-text="RAG Системы">
					RAG Системы
				</p>
				<div class="marquee-icon">
					<img src="assets/images/icon/marquee.png" alt="marquee image two">
				</div>
				<p data-text="База знаний">
					База знаний
				</p>
				<div class="marquee-icon">
					<img src="assets/images/icon/marquee.png" alt="marquee image three">
				</div>
				<p data-text="ИИ-Автоматизация">
					ИИ-Автоматизация
				</p>
				<div class="marquee-icon">
					<img src="assets/images/icon/marquee.png" alt="marquee image four">
				</div>
				<p data-text="LLM Модели">
					LLM Модели
				</p>
				<div class="marquee-icon">
