---
import Cta from "@/components/Shared/Cta.astro";
import Layout from "@/layouts/Layout.astro";
import Breadcrumb from "@/components/Shared/Breadcrumb.astro";

let chats = [];
try {
    const res = await fetch("https://api.botsync.ru/api/chats", {
        headers: {
            "accept": "application/json"
        }
    });
    if (res.ok) {
        const data = await res.json();
        chats = data.data || [];
    }
} catch (e) {
    console.error("Error fetching chats:", e);
}
---
<Layout title="Каталог ИИ чатов и ботов ассистентов" description="Пообщайтесь с ботами построенных на RAG , умные боты и ассистенты смогут ответить на ваши вопросы">
    <Breadcrumb title="Каталог умных чат ботов" />

    <!-- project section start -->
    <section class="project-section-4 pt-100 md-pt-80 pb-70 md-pb-50">
        <div class="container">
            <div class="row">
                {chats.map((chat: { name: unknown; id: any; description: unknown; }, index: number) => (
                    <div class="col-lg-6">
                        <div class="project-item right-after wow fadeInUp" data-wow-delay={`.${2 + (index % 5)}s`}>
                            <div class="project-image">
                                <figure>
                                    <img src={`assets/images/project/project-${(index % 6) + 1}.jpg`} alt={'чат бот ии:' + chat.name} />
                                </figure>
                            </div>
                            <div class="project-content">
                                <h2><a href={`/chat?id=${chat.id}`}>{chat.name}</a></h2>
                                <p>{chat.description}</p>
                                <div class="project-button-wapper">
                                    <a href={`/chat?id=${chat.id}`} class="theme-button style-1" aria-label="Пообщаться с ботом">
                                        <span data-text="Пообщаться с ботом">Пообщаться с ботом</span>
                                        <i class="fa-solid fa-arrow-right"></i>
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                ))}
            </div>
            <div class="row">
                <div class="col-12">
                    <!-- pagination start -->
                    <div class="pagination justify-content-center wow fadeInUp" data-wow-delay=".8s">
                        <nav aria-label="page navigation">
                            <ul class="page-list">
                                <li><a aria-current="page" class="page-numbers current" href="#">1</a></li>
                                <li><a class="page-numbers" href="#">2</a></li>
                                <li><a class="next page-numbers" href="#">Next Page</a></li>
                            </ul>
                        </nav>
                    </div>
                    <!-- pagination end -->
                </div>
            </div>
        </div>
    </section>
    <!-- project section end -->

    <Cta />
</Layout>