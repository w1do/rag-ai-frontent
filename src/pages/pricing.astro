---
import Layout from "@/layouts/Layout.astro";
import PricingTable from "@/components/Shared/Pricing.astro";
import Breadcrumb from "@/components/Shared/Breadcrumb.astro";

const seoData = {
    title: "Тарифы и цены на ИИ чат-ботов и RAG-системы",
    description: "Тарифы BotSync на создание умных чат-ботов с базой знаний RAG. Прозрачные цены от 100 ₽: выберите план для ИИ-ассистента на сайт с обучением нейросети на ваших данных."
};
---
<Layout title={seoData.title} description={seoData.description}>
    <Breadcrumb title="Тарифы" />

    <div class="mt-50">
        <PricingTable />
    </div>

</Layout>
