---
import Layout from "@/layouts/Layout.astro";
import Hero from "@/components/Shared/Hero.astro";
import Gallery from "@/components/Shared/Gallery.astro";
import Micon from "@/components/Shared/Micon.astro";
import ImageGenerator from "@/components/Shared/ImageGenerator.astro";
import Why from "@/components/Shared/Why.astro";
import Projects from "@/components/Shared/Projects.astro";
import MarqueeTicker from "@/components/Shared/MarqueeTicker.astro";
import HowIt from "@/components/Shared/HowIt.astro";
import Video from "@/components/Shared/Video.astro";
import Testimonials from "@/components/Shared/Testimonials.astro";
import Pricing from "@/components/Shared/Pricing.astro";
import Team from "@/components/Shared/Team.astro";
import Faq from "@/components/Shared/Faq.astro";
import Blog from "@/components/Shared/Blog.astro";

const seoData = {
    title: "ИИ для автосервиса: Умные ответы и менеджер записей | BotSync",
    description: "Автоматизируйте общение с клиентами вашего СТО. ИИ-ассистент BotSync: мгновенные ответы на вопросы, запись на сервис 24/7 и умный менеджер диалогов."
};

const miconItems = [
    { title: "Запись 24/7", desc: "Ваш ИИ-менеджер принимает заявки на ремонт и обслуживание даже ночью." },
    { title: "База знаний СТО", desc: "Бот обучен на прайс-листах и регламентах вашего сервиса для точных ответов." },
    { title: "Автоответы в мессенджерах", desc: "Мгновенная реакция на запросы в Telegram, WhatsApp и на сайте." }
];

const imageGenItems = [
    {
        icon: "assets/images/image-generator/icon-1.png",
        title: "ИИ-Менеджер записей",
        desc: "Интеллектуальный помощник, который уточняет марку авто, проблему и предлагает свободное время."
    },
    {
        icon: "assets/images/image-generator/icon-2.png",
        title: "Консультант по услугам",
        desc: "Расскажет о стоимости работ, наличии запчастей и сроках ремонта на основе вашей базы данных."
    },
    {
        icon: "assets/images/image-generator/icon-3.png",
        title: "RAG для мастеров",
        desc: "Быстрый доступ персонала к технической документации и истории обслуживания через чат."
    }
];

const marqueeItems = [
    { text: "Автосервис 2.0" },
    { text: "ИИ-Приемка" },
    { text: "Рост конверсии" },
    { text: "Автоответы" },
    { text: "Smart СТО" },
    { text: "Лояльность клиентов" }
];

const projectsItems = [
    {
        image: "assets/images/project/project-3-1.jpg",
        title: "Круглосуточный прием заявок",
        desc: "ИИ-ассистент принимает обращения в нерабочее время, уточняет проблему и предварительно записывает клиента на свободное окно.",
        features: [
            "Работа 24/7 без выходных",
            "Сбор контактных данных",
            "Интеграция с календарем СТО",
            "Уведомление мастера о записи"
        ],
        link: "#"
    },
    {
        image: "assets/images/project/project-3-2.jpg",
        title: "Консультация по услугам и ценам",
        desc: "Бот мгновенно выдает актуальную стоимость работ и запчастей, основываясь на вашем прайс-листе, повышая доверие клиента.",
        features: [
            "Точные ответы по прайсу",
            "Расчет ориентировочных сроков",
            "Информация о наличии запчастей",
            "Квалификация клиента"
        ],
        link: "#"
    },
    {
        image: "assets/images/project/project-3-3.jpg",
        title: "База знаний для мастеров",
        desc: "Внутренний ИИ-помощник для технического персонала: быстрый поиск допусков, моментов затяжки и регламентов ТО.",
        features: [
            "Мгновенный поиск в документах",
            "История обслуживания авто",
            "Подбор запчастей по VIN",
            "Доступ с мобильного телефона"
        ],
        link: "#"
    }
];

const howItSteps = [
    {
        image: "assets/images/how-it-work/icon-3-1.png",
        title: "Загрузите прайс-лист",
        desc: "Добавьте файлы с услугами, ценами и регламентами. ИИ изучит их за считанные секунды.",
        num: "01"
    },
    {
        image: "assets/images/how-it-work/icon-3-2.png",
        title: "Настройте интеграции",
        desc: "Подключите Telegram, WhatsApp и ваш сайт, чтобы ИИ мог общаться с клиентами везде.",
        num: "02"
    },
    {
        image: "assets/images/how-it-work/icon-3-3.png",
        title: "Получайте записи",
        desc: "ИИ-менеджер начнет обрабатывать запросы и передавать готовые заявки в вашу CRM.",
        num: "03"
    }
];

const whyItems = [
    {
        icon: "assets/images/why/icon-1.png",
        title: "Экономия времени мастеров",
        desc: "Мастера не отвлекаются на звонки по типовым вопросам (цена масла, наличие колодок). ИИ берет рутину на себя."
    },
    {
        icon: "assets/images/why/icon-2.png",
        title: "Голосовые заявки",
        desc: "Клиенты могут отправлять аудиосообщения — ИИ расшифрует их, поймет суть проблемы и сформирует заявку."
    },
    {
        icon: "assets/images/why/icon-3.png",
        title: "Работа без выходных",
        desc: "Ваш сервис «отвечает» клиентам 24/7. Лояльность растет, когда человек получает ответ мгновенно даже в 11 вечера."
    },
    {
        icon: "assets/images/why/icon-4.png",
        title: "Мгновенное внедрение",
        desc: "Не нужно нанимать программистов. Просто загрузите прайс и инструкции — и ваш ИИ-менеджер готов к работе."
    }
];

const faqItems = [
    {
        question: "Как ИИ понимает специфику моего автосервиса?",
        answer: "Мы используем технологию RAG: вы загружаете свой прайс-лист, перечень услуг и регламенты работ. ИИ обучается на этих данных и отвечает клиентам именно так, как ответил бы ваш лучший мастер-приемщик."
    },
    {
        question: "Сможет ли бот отличить замену масла от капитального ремонта?",
        answer: "Да, благодаря современным LLM моделям, бот понимает контекст запроса. Он уточнит детали поломки и направит клиента к нужному специалисту или предложит записаться на диагностику."
    },
    {
        question: "В каких каналах работает автоответчик?",
        answer: "Система интегрируется с вашим сайтом, Telegram, WhatsApp и другими популярными мессенджерами. Все диалоги сохраняются в единой панели управления."
    },
    {
        question: "Насколько сложно внедрить ИИ в работу СТО?",
        answer: "Внедрение занимает от 5 минут. Вам достаточно загрузить документы или дать ссылку на сайт сервиса. Настройка не требует знаний программирования."
    }
];
---

<Layout title={seoData.title} description={seoData.description}>
    <Hero 
        subTitle="Интеллектуальный менеджер для вашего СТО"
        title="ИИ-помощник для"
        titleAccent="автосервиса"
        titleMinutes="за 5 минут"
        desc="BotSync — специализированная RAG-платформа для СТО. Наш ИИ-менеджер обучается на вашем прайс-листе и регламентах, мгновенно отвечая на вопросы клиентов и записывая их на сервис 24/7."
        features={[
            "Запись на сервис",
            "Оценка стоимости",
            "Статус ремонта",
            "Интеграция с CRM",
            "Голосовые сообщения",
            "Поддержка 24/7"
        ]}
    />
    <Gallery/>
    <Micon items={miconItems}/>
    <ImageGenerator 
        titlePre="Как ИИ "
        titleAccent="BotSync"
        titlePost=" развивает ваш СТО"
        items={imageGenItems}
    />
    <Why 
        subTitle="Преимущества для бизнеса"
        titlePre="Почему СТО выбирают "
        titleAccent="автоматизацию"
        titlePost=""
        items={whyItems}
    />
    <Projects 
        titlePre="Кейсы "
        titleAccent="автосервисов"
        titlePost=""
        projects={projectsItems}
    />
    <MarqueeTicker items={marqueeItems}/>
    <HowIt 
        titlePre="Запуск ИИ-приемки за "
        titleAccent="4 шага"
        titlePost=""
        steps={howItSteps}
    />
    <Video />
    <Testimonials />
    <Pricing />
    <Team 
        titlePre="Эксперты "
        titleAccent="BotSync"
    />
    <Faq items={faqItems} />
    <Blog 
        subTitle="Автоматизация СТО"
        titlePre="Статьи об "
        titleAccent="ИИ в автобизнесе"
        titlePost=""
    />
</Layout>
