---
interface TeamMember {
    name: string;
    position: string;
    image: string;
    link?: string;
}

interface Skill {
    title: string;
    percent: string;
}

interface Props {
    subTitle?: string;
    titlePre?: string;
    titleAccent?: string;
    titlePost?: string;
    members?: TeamMember[];
    leadName?: string;
    leadPosition?: string;
    leadImage?: string;
    leadDesc?: string;
    leadSkills?: Skill[];
}

const {
    subTitle = "Наша команда",
    titlePre = "Эксперты в области ",
    titleAccent = "ИИ и RAG",
    titlePost = "",
    members = [
        { name: "Екатерина Денисова", position: "Ведущий ML-инженер", image: "assets/images/team/team-3-1.jpg", link: "#" },
        { name: "Лоренс Оливье", position: "Архитектор RAG-систем", image: "assets/images/team/team-3-2.jpg", link: "#" },
        { name: "Сюзанна Хопкинс", position: "Специалист по LLM", image: "assets/images/team/team-3-3.jpg", link: "#" }
    ],
    leadName = "Денис Митрофанов",
    leadPosition = "CTO / Разработчик",
    leadImage = "assets/images/team/team-3-4.jpg",
    leadDesc = "Мы объединяем передовые технологии и глубокое понимание бизнес-процессов, чтобы создавать ИИ-решения, которые действительно работают.",
    leadSkills = [
        { title: "RAG", percent: "95%" },
        { title: "Внедрение ИИ", percent: "85%" },
        { title: "Написание кода с помощью LLM", percent: "99%" }
    ]
} = Astro.props;
---
<!-- team section start -->
<section class="team-section-1 pb-70 md-pb-50">
    <div class="container">
        <div class="row">
            <div class="col-lg-12">
                <!-- section title start -->
                <div class="section-title text-center wow fadeInUp" data-wow-delay=".2s">
                    <span class="sub-title">{subTitle}</span>
                    <h2>{titlePre}<span>{titleAccent}</span>{titlePost}</h2>
                </div>
                <!-- section title end -->
            </div>
        </div>
        <div class="row">
            <div class="col-xxl-6 col-xl-6 col-lg-12">
                <!-- team list start -->
                <div class="team-list">
                    {members.map((member) => (
                        <div class="team-item right-after align-items-center">
                            <div class="team-image">
                                <figure>
                                    <img src={member.image} alt={member.name}>
                                </figure>
                            </div>
                            <div class="team-content">
                                <h2><a href={member.link}>{member.name}</a></h2>
                                <p class="designation">{member.position}</p>
                            </div>
                        </div>
                    ))}
                </div>
                <!-- team list end -->
            </div>
            <div class="col-xxl-6 col-xl-6 col-lg-12">
                <!-- team-item start -->
                <div class="team-item item-right right-after">
                    <div class="team-image">
                        <figure>
                            <img src={leadImage} alt={leadName}>
                        </figure>
                    </div>
                    <div class="team-content">
                        <h2><a href="#">{leadName}</a></h2>
                        <p class="designation">{leadPosition}</p>
                        <div class="team-more-details mt-30">
                            <p class="desc mb-20">{leadDesc}</p>
                            <!-- progress wapper start -->
                            <div class="progress-wapper mb-40">
                                {leadSkills.map((skill) => (
                                    <div class="single-progressbar">
                                        <div class="progress-title">{skill.title}</div>
                                        <div class="progressbar">
                                            <div class="progress-bar-count counted" data-percent={skill.percent}></div>
                                        </div>
                                    </div>
                                ))}
                            </div>
                            <!-- progress wapper end -->
                            <!-- footer social icon start -->
                            <div class="footer-social-icon">
                                <ul class="social-icon">
                                    <li><a href="#" aria-label="instagram"><i class="fa-brands fa-instagram"></i></a></li>
                                    <li><a href="#" aria-label="facebook"><i class="fa-brands fa-facebook-f"></i></a></li>
                                    <li><a href="#" aria-label="twitter"><i class="fa-brands fa-x-twitter"></i></a></li>
                                    <li><a href="#" aria-label="pinterest"><i class="fa-brands fa-pinterest-p"></i></a></li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
<!-- team section end -->