---
interface MiconItem {
    title: string;
    desc: string;
}

interface Props {
    items?: MiconItem[];
}

const {
    items = [
        {
            title: "Быстрое <br> Обучение",
            desc: "Загрузите документы, и ваш ИИ-агент будет готов к работе уже через несколько минут."
        },
        {
            title: "Точные <br> Ответы",
            desc: "Технология RAG гарантирует, что ИИ использует только проверенную информацию из вашей базы знаний."
        },
        {
            title: "Гибкие <br> Настройки",
            desc: "Настройте тон общения, роль и поведение ИИ под специфику вашего бизнеса и бренда."
        }
    ]
} = Astro.props;
---
<!-- micon section start -->
<section class="micon-section pt-100 md-pt-80">
    <div class="container">
        <div class="row">
            <div class="col-lg-12">
                <!-- micon wapper start -->
                <div class="micon-wapper">
                    {items.map((item, index) => (
                        <div class="micon-items right-after wow fadeInUp" data-wow-delay={`${0.3 + index * 0.1}s`}>
                            <div class="micon-content">
                                <h2 fragment set:html={item.title}></h2>
                                <p>{item.desc}</p>
                            </div>
                        </div>
                    ))}
                </div>
                <!-- micon wapper end -->
            </div>
        </div>
    </div>
</section>
<!-- micon section end -->