---
const {
    inputPlaceholder = "Опишите, какую задачу должен решать ваш ИИ-бот...",
} = Astro.props
---
<div class="hero-input-box">
    <div id="chat-messages-container" class="mt-8 space-y-6 max-h-[450px] overflow-y-auto pr-3 custom-scrollbar hidden bg-white/[0.02] rounded-3xl p-4 border border-white/5 shadow-inner">
        <!-- Messages will be appended here -->
    </div>

    <form action="#" class="input-form mt-6 relative group" id="chat-hero-form">
        <div class="hero-input-group !bg-white/[0.05] !border-white/10 !rounded-2xl focus-within:!border-orange-500/50 transition-all duration-300 shadow-lg">
            <textarea name="question" id="chat-question"
                      class="!text-white !placeholder-white/30 !py-4"
                      placeholder={inputPlaceholder}></textarea>
        </div>
        <div class="hero-input-buttons mt-4 flex items-center justify-between">
            <div class="hero-button-left flex gap-4">
                <div class="hero-plus">
                    <a href="#" aria-label="plus" class="hover:text-orange-500 transition-colors"><i class="fa-solid fa-plus"></i></a>
                </div>
                <div class="hero-tool">
                    <a href="#" aria-label="tools" class="text-white/40 hover:text-white transition-colors text-sm flex items-center gap-2">
                        <i class="fa-solid fa-sliders text-orange-500"></i> Настройки
                    </a>
                </div>
            </div>
            <div class="hero-button-right">
                <button type="submit" class="submit-btn !bg-orange-500 hover:!bg-orange-600 !text-white !rounded-xl !w-12 !h-12 flex items-center justify-center transition-all shadow-[0_10px_20px_rgba(249,115,22,0.2)] hover:scale-105" aria-label="paper plane">
                    <i class="fa-solid fa-paper-plane"></i>
                </button>
            </div>
        </div>
    </form>
</div>
