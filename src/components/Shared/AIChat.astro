---
// AIChat — полноценный чат с ИИ-ассистентом в стиле сайта.
// Клиент задаёт вопрос, бот отвечает. Запрос уходит на эндпоинт share-chat.
interface Props {
    title?: string;
    subtitle?: string;
    assistantName?: string;
    inputPlaceholder?: string;
    greeting?: string;
    /** Базовый адрес API (без завершающего слэша). Пусто = тот же origin. */
    apiBase?: string;
    /** Идентификатор share-chat сессии. */
    chatId?: number | string;
}

const {
    title = "Чат с ИИ-ассистентом",
    subtitle = "Спросите что угодно — умный ИИ-агент BotSync ответит мгновенно",
    assistantName = "BotSync ИИ",
    inputPlaceholder = "Напишите сообщение...",
    greeting = "Здравствуйте! Я — ИИ-ассистент BotSync. Чем могу помочь?",
    apiBase = "http://localhost/",
    chatId = 2,
} = Astro.props;

// Нормализуем базовый адрес: убираем завершающий слэш, чтобы не получить
// двойной слэш (http://localhost//share-chat/...), который ломает запрос.
const normalizedBase = apiBase.replace(/\/+$/, "");
const endpoint = `${normalizedBase}/share-chat/${chatId}/message`;
---

<section class="ai-chat-section">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-9 col-xl-8">
                <div
                    class="ai-chat"
                    data-endpoint={endpoint}
                    data-assistant={assistantName}
                    data-greeting={greeting}
                >
                    <!-- header -->
                    <div class="ai-chat__header">
                        <div class="ai-chat__avatar" aria-hidden="true">
                            <i class="fa-solid fa-robot"></i>
                            <span class="ai-chat__status-dot"></span>
                        </div>
                        <div class="ai-chat__heading">
                            <h3 class="ai-chat__title">{title}</h3>
                            <p class="ai-chat__subtitle">{subtitle}</p>
                        </div>
                        <span class="ai-chat__online">
                            <span class="ai-chat__online-dot"></span> Онлайн
                        </span>
                    </div>

                    <!-- messages -->
                    <div
                        class="ai-chat__messages custom-scrollbar"
                        id="ai-chat-messages"
                        role="log"
                        aria-live="polite"
                        aria-label="История сообщений чата"
                    >
                        <!-- messages are injected here -->
                    </div>

                    <!-- input -->
                    <form class="ai-chat__form" id="ai-chat-form" autocomplete="off">
                        <div class="ai-chat__input-wrap">
                            <textarea
                                id="ai-chat-input"
                                name="question"
                                class="ai-chat__input"
                                rows="1"
                                placeholder={inputPlaceholder}
                                aria-label="Текст сообщения"
                            ></textarea>
                            <button
                                type="submit"
                                class="ai-chat__send"
                                id="ai-chat-send"
                                aria-label="Отправить сообщение"
                            >
                                <i class="fa-solid fa-paper-plane"></i>
                            </button>
                        </div>
                        <p class="ai-chat__hint">
                            Нажмите <kbd>Enter</kbd> для отправки, <kbd>Shift</kbd>+<kbd>Enter</kbd> — новая строка
                        </p>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>

<style is:global>
    .ai-chat-section {
        padding: 80px 0;
        position: relative;
    }

    .ai-chat {
        display: flex;
        flex-direction: column;
        background: var(--background-one, #191919);
        border: 1px solid var(--border-color-one, rgba(255, 255, 255, 0.1));
        border-radius: var(--border-radius-three, 24px);
        overflow: hidden;
        box-shadow: 0 30px 80px -40px rgba(0, 0, 0, 0.8);
        height: 640px;
        max-height: 80vh;
    }

    /* ---------- header ---------- */
    .ai-chat__header {
        display: flex;
        align-items: center;
        gap: 16px;
        padding: 20px 24px;
        border-bottom: 1px solid var(--border-color-one, rgba(255, 255, 255, 0.1));
        background: rgba(255, 255, 255, 0.02);
    }

    .ai-chat__avatar {
        position: relative;
        flex-shrink: 0;
        width: 52px;
        height: 52px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 50%;
        background: var(--primary-rgb-12, rgba(221, 255, 0, 0.123));
        color: var(--primary-color, #DFFF00);
        font-size: 22px;
    }

    .ai-chat__status-dot {
        position: absolute;
        right: 2px;
        bottom: 2px;
        width: 12px;
        height: 12px;
        border-radius: 50%;
        background: #22c55e;
        border: 2px solid var(--background-one, #191919);
    }

    .ai-chat__heading {
        flex: 1;
        min-width: 0;
    }

    .ai-chat__title {
        font-family: var(--title-fonts, "Unbounded", sans-serif);
        font-size: 18px;
        font-weight: 600;
        margin: 0;
        color: var(--white-color, #fff);
    }

    .ai-chat__subtitle {
        margin: 4px 0 0;
        font-size: 13px;
        line-height: 1.4;
        color: rgba(255, 255, 255, 0.45);
    }

    .ai-chat__online {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-size: 12px;
        color: rgba(255, 255, 255, 0.55);
        white-space: nowrap;
    }

    .ai-chat__online-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: #22c55e;
        box-shadow: 0 0 0 4px rgba(34, 197, 94, 0.15);
    }

    /* ---------- messages ---------- */
    .ai-chat__messages {
        flex: 1;
        overflow-y: auto;
        padding: 24px;
        display: flex;
        flex-direction: column;
        gap: 18px;
    }

    .ai-chat__row {
        display: flex;
        gap: 12px;
        max-width: 85%;
        animation: ai-chat-in 0.3s ease both;
    }

    .ai-chat__row--user {
        align-self: flex-end;
        flex-direction: row-reverse;
    }

    .ai-chat__row-avatar {
        flex-shrink: 0;
        width: 36px;
        height: 36px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 15px;
    }

    .ai-chat__row--bot .ai-chat__row-avatar {
        background: var(--primary-rgb-12, rgba(221, 255, 0, 0.123));
        color: var(--primary-color, #DFFF00);
    }

    .ai-chat__row--user .ai-chat__row-avatar {
        background: rgba(255, 255, 255, 0.08);
        color: rgba(255, 255, 255, 0.7);
    }

    .ai-chat__content {
        display: flex;
        flex-direction: column;
        gap: 5px;
        min-width: 0;
    }

    /* Подпись отправителя в виде бейджика */
    .ai-chat__name {
        display: inline-flex;
        align-items: center;
        align-self: flex-start;
        font-size: 12px;
        font-weight: 600;
        letter-spacing: 0.02em;
        padding: 3px 10px;
        border-radius: 999px;
        line-height: 1.3;
    }

    /* Ассистент — жёлтый бейджик */
    .ai-chat__row--bot .ai-chat__name {
        color: var(--black-color, #000);
        background: var(--primary-color, #DFFF00);
    }

    .ai-chat__row--user .ai-chat__content {
        align-items: flex-end;
    }

    /* Я — сероватый бейджик */
    .ai-chat__row--user .ai-chat__name {
        align-self: flex-end;
        color: rgba(255, 255, 255, 0.85);
        background: rgba(255, 255, 255, 0.1);
    }

    /* "печатает" — пульсирующий текст в рамке во время ожидания ответа */
    .ai-chat__row--typing .ai-chat__name {
        background: transparent;
        color: var(--primary-color, #DFFF00);
        border: 1px solid var(--primary-color, #DFFF00);
        padding: 3px 12px;
        animation: ai-chat-pulse 1.2s ease-in-out infinite;
    }

    @keyframes ai-chat-pulse {
        0%, 100% {
            opacity: 0.45;
            box-shadow: 0 0 0 0 var(--primary-rgb-12, rgba(221, 255, 0, 0.123));
        }
        50% {
            opacity: 1;
            box-shadow: 0 0 0 4px var(--primary-rgb-12, rgba(221, 255, 0, 0.123));
        }
    }

    .ai-chat__bubble {
        padding: 12px 16px;
        border-radius: 18px;
        font-size: 15px;
        line-height: 1.55;
        word-break: break-word;
    }

    /* ---------- markdown ---------- */
    .ai-chat__bubble p {
        margin: 0 0 8px;
        font-size: inherit;
        line-height: inherit;
        color: inherit;
    }

    .ai-chat__bubble p:last-child {
        margin-bottom: 0;
    }

    .ai-chat__bubble h1,
    .ai-chat__bubble h2,
    .ai-chat__bubble h3,
    .ai-chat__bubble h4 {
        margin: 6px 0 8px;
        font-family: var(--title-fonts, "Unbounded", sans-serif);
        line-height: 1.3;
    }

    .ai-chat__bubble h1 { font-size: 19px; }
    .ai-chat__bubble h2 { font-size: 17px; }
    .ai-chat__bubble h3 { font-size: 16px; }
    .ai-chat__bubble h4 { font-size: 15px; }

    .ai-chat__bubble ul,
    .ai-chat__bubble ol {
        margin: 4px 0 8px;
        padding-left: 20px;
    }

    .ai-chat__bubble li {
        margin: 2px 0;
    }

    .ai-chat__bubble a {
        color: var(--primary-color, #DFFF00);
        text-decoration: underline;
    }

    .ai-chat__row--user .ai-chat__bubble a {
        color: inherit;
    }

    .ai-chat__bubble code {
        background: rgba(0, 0, 0, 0.35);
        padding: 1px 6px;
        border-radius: 5px;
        font-size: 13px;
        font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    }

    .ai-chat__row--user .ai-chat__bubble code {
        background: rgba(0, 0, 0, 0.12);
    }

    .ai-chat__bubble pre {
        background: rgba(0, 0, 0, 0.4);
        padding: 12px 14px;
        border-radius: 10px;
        overflow-x: auto;
        margin: 6px 0 8px;
    }

    .ai-chat__bubble pre code {
        background: transparent;
        padding: 0;
    }

    .ai-chat__bubble blockquote {
        margin: 6px 0;
        padding-left: 12px;
        border-left: 3px solid var(--primary-color, #DFFF00);
        color: rgba(255, 255, 255, 0.75);
    }

    .ai-chat__bubble strong { font-weight: 700; }
    .ai-chat__bubble em { font-style: italic; }

    .ai-chat__row--bot .ai-chat__bubble {
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid var(--border-color-one, rgba(255, 255, 255, 0.1));
        color: rgba(255, 255, 255, 0.92);
        border-top-left-radius: 4px;
    }

    .ai-chat__row--user .ai-chat__bubble {
        background: var(--primary-color, #DFFF00);
        color: var(--black-color, #000);
        font-weight: 500;
        border-top-right-radius: 4px;
    }

    .ai-chat__bubble--error {
        background: rgba(239, 68, 68, 0.12) !important;
        border-color: rgba(239, 68, 68, 0.4) !important;
        color: #fca5a5 !important;
    }

    /* typing indicator */
    .ai-chat__typing {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 14px 16px;
    }

    .ai-chat__typing span {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: var(--primary-color, #DFFF00);
        opacity: 0.5;
        animation: ai-chat-bounce 1.2s infinite ease-in-out;
    }

    .ai-chat__typing span:nth-child(2) {
        animation-delay: 0.2s;
    }

    .ai-chat__typing span:nth-child(3) {
        animation-delay: 0.4s;
    }

    /* ---------- form ---------- */
    .ai-chat__form {
        padding: 16px 20px 20px;
        border-top: 1px solid var(--border-color-one, rgba(255, 255, 255, 0.1));
        background: rgba(255, 255, 255, 0.02);
    }

    .ai-chat__input-wrap {
        display: flex;
        align-items: flex-end;
        gap: 12px;
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid var(--border-color-one, rgba(255, 255, 255, 0.1));
        border-radius: 16px;
        padding: 8px 8px 8px 18px;
        transition: border-color 0.3s ease, box-shadow 0.3s ease;
    }

    .ai-chat__input-wrap:focus-within {
        border-color: var(--primary-color, #DFFF00);
        box-shadow: 0 0 0 3px var(--primary-rgb-12, rgba(221, 255, 0, 0.123));
    }

    .ai-chat__input {
        flex: 1;
        background: transparent;
        border: none;
        outline: none;
        resize: none;
        color: var(--white-color, #fff);
        font-family: var(--body-fonts, "DM Sans", sans-serif);
        font-size: 15px;
        line-height: 1.5;
        max-height: 140px;
        padding: 10px 0;
    }

    .ai-chat__input::placeholder {
        color: rgba(255, 255, 255, 0.3);
    }

    .ai-chat__send {
        flex-shrink: 0;
        width: 46px;
        height: 46px;
        border: none;
        border-radius: 12px;
        background: var(--primary-color, #DFFF00);
        color: var(--black-color, #000);
        font-size: 16px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: transform 0.2s ease, opacity 0.2s ease, background 0.2s ease;
    }

    .ai-chat__send:hover:not(:disabled) {
        transform: scale(1.06);
    }

    .ai-chat__send:disabled {
        opacity: 0.45;
        cursor: not-allowed;
    }

    .ai-chat__hint {
        margin: 10px 4px 0;
        font-size: 12px;
        color: rgba(255, 255, 255, 0.3);
    }

    .ai-chat__hint kbd {
        background: rgba(255, 255, 255, 0.08);
        border-radius: 4px;
        padding: 1px 6px;
        font-size: 11px;
        font-family: var(--body-fonts, "DM Sans", sans-serif);
    }

    /* ---------- scrollbar ---------- */
    .ai-chat__messages::-webkit-scrollbar {
        width: 6px;
    }

    .ai-chat__messages::-webkit-scrollbar-track {
        background: transparent;
    }

    .ai-chat__messages::-webkit-scrollbar-thumb {
        background: rgba(255, 255, 255, 0.12);
        border-radius: 3px;
    }

    .ai-chat__messages::-webkit-scrollbar-thumb:hover {
        background: rgba(255, 255, 255, 0.25);
    }

    @keyframes ai-chat-in {
        from {
            opacity: 0;
            transform: translateY(10px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @keyframes ai-chat-bounce {
        0%, 60%, 100% {
            transform: translateY(0);
            opacity: 0.4;
        }
        30% {
            transform: translateY(-6px);
            opacity: 1;
        }
    }

    @media (max-width: 575px) {
        .ai-chat-section {
            padding: 48px 0;
        }
        .ai-chat {
            height: 78vh;
            border-radius: 18px;
        }
        .ai-chat__row {
            max-width: 92%;
        }
        .ai-chat__online {
            display: none;
        }
    }
</style>

<script>
    interface ChatConfig {
        endpoint: string;
        assistant: string;
        greeting: string;
    }

    function initAIChat(root: HTMLElement): void {
        const messages = root.querySelector<HTMLElement>("#ai-chat-messages");
        const form = root.querySelector<HTMLFormElement>("#ai-chat-form");
        const input = root.querySelector<HTMLTextAreaElement>("#ai-chat-input");
        const sendBtn = root.querySelector<HTMLButtonElement>("#ai-chat-send");

        if (!messages || !form || !input || !sendBtn) return;

        const cfg: ChatConfig = {
            endpoint: root.dataset.endpoint || "/share-chat/2/message",
            assistant: root.dataset.assistant || "ИИ",
            greeting: root.dataset.greeting || "",
        };

        let busy = false;

        // Экранируем HTML, чтобы ответ ассистента не мог внедрить разметку.
        const escapeHtml = (s: string): string =>
            s
                .replace(/&/g, "&amp;")
                .replace(/</g, "&lt;")
                .replace(/>/g, "&gt;");

        // Лёгкий конвертер Markdown -> HTML для ответов ассистента.
        const renderMarkdown = (src: string): string => {
            // Блоки кода ```...``` выносим заранее, чтобы не трогать их содержимое.
            const codeBlocks: string[] = [];
            let text = src.replace(/```(?:[^\n`]*)\n?([\s\S]*?)```/g, (_m, code) => {
                codeBlocks.push(`<pre><code>${escapeHtml(code.replace(/\n$/, ""))}</code></pre>`);
                return `\u0000CODE${codeBlocks.length - 1}\u0000`;
            });

            text = escapeHtml(text);

            const inline = (s: string): string =>
                s
                    .replace(/`([^`]+)`/g, "<code>$1</code>")
                    .replace(/\*\*([^*]+)\*\*/g, "<strong>$1</strong>")
                    .replace(/__([^_]+)__/g, "<strong>$1</strong>")
                    .replace(/(^|[^*])\*([^*\n]+)\*/g, "$1<em>$2</em>")
                    .replace(/(^|[^_])_([^_\n]+)_/g, "$1<em>$2</em>")
                    .replace(
                        /\[([^\]]+)\]\((https?:\/\/[^\s)]+)\)/g,
                        '<a href="$2" target="_blank" rel="noopener noreferrer">$1</a>'
                    )
                    .replace(
                        /(^|[\s])(https?:\/\/[^\s<]+)/g,
                        '$1<a href="$2" target="_blank" rel="noopener noreferrer">$2</a>'
                    );

            const lines = text.split(/\n/);
            const html: string[] = [];
            let listType: "ul" | "ol" | null = null;
            let paragraph: string[] = [];

            const flushParagraph = (): void => {
                if (paragraph.length) {
                    html.push(`<p>${inline(paragraph.join(" "))}</p>`);
                    paragraph = [];
                }
            };
            const closeList = (): void => {
                if (listType) {
                    html.push(`</${listType}>`);
                    listType = null;
                }
            };

            for (const raw of lines) {
                const line = raw.trim();
                if (!line) {
                    flushParagraph();
                    closeList();
                    continue;
                }
                if (/^\u0000CODE\d+\u0000$/.test(line)) {
                    flushParagraph();
                    closeList();
                    html.push(line);
                    continue;
                }
                const heading = line.match(/^(#{1,4})\s+(.*)$/);
                if (heading) {
                    flushParagraph();
                    closeList();
                    const level = heading[1].length;
                    html.push(`<h${level}>${inline(heading[2])}</h${level}>`);
                    continue;
                }
                if (/^>\s?/.test(line)) {
                    flushParagraph();
                    closeList();
                    html.push(`<blockquote>${inline(line.replace(/^>\s?/, ""))}</blockquote>`);
                    continue;
                }
                const ul = line.match(/^[-*+]\s+(.*)$/);
                const ol = line.match(/^\d+\.\s+(.*)$/);
                if (ul || ol) {
                    flushParagraph();
                    const type = ul ? "ul" : "ol";
                    if (listType !== type) {
                        closeList();
                        listType = type;
                        html.push(`<${type}>`);
                    }
                    html.push(`<li>${inline((ul ? ul[1] : (ol as RegExpMatchArray)[1]))}</li>`);
                    continue;
                }
                closeList();
                paragraph.push(line);
            }
            flushParagraph();
            closeList();

            let result = html.join("");
            result = result.replace(/\u0000CODE(\d+)\u0000/g, (_m, i) => codeBlocks[Number(i)]);
            return result;
        };

        const scrollToBottom = (): void => {
            messages.scrollTop = messages.scrollHeight;
        };

        const addMessage = (text: string, role: "user" | "bot", isError = false): void => {
            const row = document.createElement("div");
            row.className = `ai-chat__row ai-chat__row--${role}`;

            const content = document.createElement("div");
            content.className = "ai-chat__content";

            const name = document.createElement("span");
            name.className = "ai-chat__name";
            name.textContent = role === "bot" ? "Ассистент" : "Я";

            const bubble = document.createElement("div");
            bubble.className = "ai-chat__bubble" + (isError ? " ai-chat__bubble--error" : "");
            // Ответы ассистента приходят в Markdown — рендерим в HTML.
            // Сообщения пользователя и ошибки выводим обычным текстом.
            if (role === "bot" && !isError) {
                bubble.innerHTML = renderMarkdown(text);
            } else {
                bubble.textContent = text;
            }

            content.appendChild(name);
            content.appendChild(bubble);
            row.appendChild(content);
            messages.appendChild(row);
            scrollToBottom();
        };

        const showTyping = (): HTMLElement => {
            const row = document.createElement("div");
            row.className = "ai-chat__row ai-chat__row--bot ai-chat__row--typing";
            row.innerHTML =
                '<div class="ai-chat__content">' +
                '<span class="ai-chat__name">Ассистент печатает</span>' +
                '<div class="ai-chat__bubble"><span class="ai-chat__typing"><span></span><span></span><span></span></span></div>' +
                '</div>';
            messages.appendChild(row);
            scrollToBottom();
            return row;
        };

        const autoResize = (): void => {
            input.style.height = "auto";
            input.style.height = Math.min(input.scrollHeight, 140) + "px";
        };

        const setBusy = (state: boolean): void => {
            busy = state;
            sendBtn.disabled = state;
        };

        const sendQuestion = async (question: string): Promise<void> => {
            setBusy(true);
            const typing = showTyping();

            // Прерываем запрос, если ассистент не ответил за 30 секунд.
            const controller = new AbortController();
            const timeoutId = window.setTimeout(() => controller.abort(), 30000);

            try {
                const res = await fetch(cfg.endpoint, {
                    method: "POST",
                    headers: {
                        "Accept": "application/json",
                        "Content-Type": "application/json",
                        "X-CSRF-TOKEN": "",
                    },
                    body: JSON.stringify({ question }),
                    signal: controller.signal,
                });

                typing.remove();

                if (!res.ok) {
                    throw new Error(`HTTP ${res.status} ${res.statusText}`);
                }

                const data = await res.json();
                const answer =
                    (data && (data.answer ?? data.message ?? data.response)) ||
                    "Извините, не удалось получить ответ.";
                addMessage(String(answer), "bot");
            } catch (err) {
                typing.remove();
                // Выводим реальную причину в консоль — помогает отличить
                // сетевую/CORS-ошибку от таймаута или ошибки сервера.
                console.error("[AIChat] Ошибка запроса к", cfg.endpoint, err);
                const aborted = err instanceof DOMException && err.name === "AbortError";
                addMessage(
                    aborted
                        ? "Ассистент не ответил вовремя. Пожалуйста, попробуйте ещё раз."
                        : "Не удалось связаться с ассистентом. Пожалуйста, попробуйте ещё раз.",
                    "bot",
                    true
                );
            } finally {
                window.clearTimeout(timeoutId);
                setBusy(false);
                input.focus();
            }
        };

        const submit = (): void => {
            const value = input.value.trim();
            if (!value || busy) return;
            addMessage(value, "user");
            input.value = "";
            autoResize();
            void sendQuestion(value);
        };

        form.addEventListener("submit", (e) => {
            e.preventDefault();
            submit();
        });

        input.addEventListener("input", autoResize);

        input.addEventListener("keydown", (e) => {
            if (e.key === "Enter" && !e.shiftKey) {
                e.preventDefault();
                submit();
            }
        });

        // greeting
        if (cfg.greeting) {
            addMessage(cfg.greeting, "bot");
        }
        input.focus();
    }

    document.querySelectorAll<HTMLElement>(".ai-chat").forEach(initAIChat);
</script>
