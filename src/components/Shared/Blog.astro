---
interface BlogPost {
    image: string;
    author: string;
    date: string;
    title: string;
    link?: string;
}

interface Props {
    subTitle?: string;
    titlePre?: string;
    titleAccent?: string;
    titlePost?: string;
    desc?: string;
    posts?: BlogPost[];
}

const {
    subTitle = "Блог об ИИ",
    titlePre = "Новости и ",
    titleAccent = "советы",
    titlePost = " по автоматизации",
    desc = "Узнайте больше о том, как искусственный интеллект и RAG-системы меняют современный бизнес.",
    posts = [
        {
            image: "assets/images/blog/blog-1.jpg",
            author: "Admin",
            date: "March 14, 2025",
            title: "Как подготовить базу знаний для обучения ИИ-бота",
            link: "#"
        },
        {
            image: "assets/images/blog/blog-2.jpg",
            author: "Admin",
            date: "March 14, 2025",
            title: "Топ-10 инструментов для ИИ-автоматизации в 2026 году",
            link: "#"
        },
        {
            image: "assets/images/blog/blog-3.jpg",
            author: "Admin",
            date: "March 14, 2025",
            title: "Преимущества RAG перед обычными чат-ботами",
            link: "#"
        }
    ]
} = Astro.props;
---
<!-- blog section start -->
<section id="contact" class="blog-section pt-100 md-pt-80 pb-70 md-pb-50">
    <div class="container">
        <div class="row">
            <div class="col-lg-12">
                <!-- section title start -->
                <div class="section-title text-center wow fadeInUp" data-wow-delay=".2s">
                    <span class="sub-title">{subTitle}</span>
                    <h2>{titlePre}<span>{titleAccent}</span>{titlePost}</h2>
                    <p>{desc}</p>
                </div>
                <!-- section title end -->
            </div>
        </div>
        <div class="row">
            {posts.map((post, index) => (
                <div class="col-lg-4 col-md-12">
                    <!-- blog grid item start -->
                    <div class="blog-grid-item-1 right-after wow fadeInUp" data-wow-delay={`${0.3 + index * 0.1}s`}>
                        <!-- blog grid image start -->
                        <div class="blog-grid-image">
                            <a href="blog-details.html">
                                <figure class="image-anime">
                                    <img src={post.image} alt={post.title}>
                                </figure>
                            </a>
                        </div>
                        <!-- blog grid image end -->
                        <!-- blog grid content start -->
                        <div class="blog-grid-content">
                            <ul class="blog-meta">
                                <li>
                                    <a href="#">
                                        <i class="fa-solid fa-user"></i>
                                        <span>{post.author}</span>
                                    </a>
                                </li>
                                <li>
                                    <i class="fa-solid fa-calendar-days"></i>
                                    <span>{post.date}</span>
                                </li>
                            </ul>
                            <h2><a href={post.link}>{post.title}</a></h2>
                            <div class="blog-grid-button">
                                <a href={post.link} class="read-more-btn">Подробнее</a>
                            </div>
                        </div>
                        <!-- blog grid content end -->
                    </div>
                    <!-- blog grid item end -->
                </div>
            ))}
        </div>
    </div>
</section>
<!-- blog section end -->