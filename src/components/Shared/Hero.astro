---
interface Props {
    subTitle?: string;
    title?: string;
    titleAccent?: string;
    titleMinutes?: string;
    desc?: string;
    inputPlaceholder?: string;
    features?: string[];
}

const {
    subTitle = "ИИ-автоматизация для масштабируемого бизнеса",
    title = "Создайте умного",
    titleAccent = "ИИ-агента",
    titleMinutes = "за 5 минут",
    desc = "BotSync — лучшая RAG-платформа для бизнеса. Наш конструктор ИИ-ботов позволяет обучить ассистента на ваших документах, базе знаний и сайте мгновенно. Автоматизируйте поддержку и продажи с помощью передовых технологий LLM.",
    inputPlaceholder = "Опишите, какую задачу должен решать ваш ИИ-бот...",
    features = [
        "Обучение на PDF",
        "Парсинг сайтов",
        "Голосовые RAG",
        "Интеграция по API",
        "Виджет на сайт",
        "JSON данные"
    ]
} = Astro.props;
---
<!-- hero section start -->
<section class="hero-section-3">
    <!-- bakground assets start -->
    <div class="bakground-assets">
        <img class="line-top" src="assets/images/hero/bg-line-two.png" alt="hero line">
        <img class="shape-one" src="assets/images/hero/light-shape-1.png" alt="hero light shape one">
        <img class="shape-two" src="assets/images/hero/light-shape-2.png" alt="hero light shape two">
    </div>
    <!-- bakground assets end -->
    <div class="container">
        <div class="row">
            <div class="col-12">
                <!-- hero wapper start -->
                <div class="hero-wapper">
                    <!-- hero content start -->
                    <div class="hero-content">
                        <div class="section-title align-items-center">
                            <span class="sub-title">{subTitle}</span>
                            <h1>{title}
                                <span>{titleAccent}</span>
                                <span class="prompt">
                                                <svg class="circle1" width="8" height="8" viewBox="0 0 8 8" fill="none"
                                                     xmlns="http://www.w3.org/2000/svg">
                                                    <circle cx="4" cy="4" r="4" fill="currentColor"></circle>
                                                </svg>
                                                <svg class="circle2" width="8" height="8" viewBox="0 0 8 8" fill="none"
                                                     xmlns="http://www.w3.org/2000/svg">
                                                    <circle cx="4" cy="4" r="4" fill="currentColor"></circle>
                                                </svg>
                                                {titleMinutes}
                                                <svg class="circle3" width="8" height="8" viewBox="0 0 8 8" fill="none"
                                                     xmlns="http://www.w3.org/2000/svg">
                                                    <circle cx="4" cy="4" r="4" fill="currentColor"></circle>
                                                </svg>
                                                <svg class="circle4" width="8" height="8" viewBox="0 0 8 8" fill="none"
                                                     xmlns="http://www.w3.org/2000/svg">
                                                    <circle cx="4" cy="4" r="4" fill="currentColor"></circle>
                                                </svg>
                                            </span>
                                <img src="assets/images/hero/tag-image.png" alt="tag image">
                            </h1>
                            <p class="desc">{desc}</p>
                        </div>

                        <div class="hero-input-box">
                            <form action="#" class="input-form" id="input-forms">
                                <div class="hero-input-group">
                                                <textarea name="search" id="search"
                                                          placeholder={inputPlaceholder}></textarea>
                                </div>
                                <div class="hero-input-buttons">
                                    <div class="hero-button-left">
                                        <div class="hero-plus">
                                            <a href="#" aria-label="plus"><i class="fa-solid fa-plus"></i></a>
                                        </div>
                                        <div class="hero-tool">
                                            <a href="#" aria-label="tools"><i class="fa-solid fa-sliders"></i> Настройки</a>
                                        </div>
                                    </div>
                                    <div class="hero-button-right">
                                        <button type="submit" class="submit-btn" data-text="Создать" aria-label="paper plane">
                                            <i class="fa-solid fa-paper-plane"></i>
                                        </button>
                                    </div>
                                </div>
                            </form>
                        </div>

                        <div class="hero-footer">
                            <ul>
                                {features.map((feature) => (
                                    <li>{feature}</li>
                                ))}
                            </ul>
                        </div>

                    </div>
                    <!-- hero content end -->
                </div>
                <!-- hero wapper end -->
            </div>
        </div>
    </div>
</section>
<!-- hero section end -->
