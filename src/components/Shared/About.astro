---
export interface AboutFeature {
    icon?: string;
    title: string;
    desc: string;
}

export interface Props {
    subTitle?: string;
    title: string;
    titleAccent?: string;
    desc?: string;
    paragraphs?: string[];
    features?: AboutFeature[];
    phone?: string;
    phoneLabel?: string;
    image?: string;
    contentTitle?: string;
    contentItems?: { title: string; desc: string }[];
}

const {
    subTitle = "О боте",
    title,
    titleAccent = "",
    desc = "",
    paragraphs = [],
    features = [],
    phone,
    phoneLabel = "Связаться с нами",
    image = "/assets/images/about/about-2-1-1.jpg",
    contentTitle,
    contentItems = [],
} = Astro.props;
---

<!-- about section start -->
<section class="about-section-2 pt-100 md-pt-80 pb-100 md-pb-80">
    <div class="container">
        <div class="row">
            <div class="col-lg-6">
                <!-- about left start -->
                <div class="about-left wow fadeInUp" data-wow-delay=".2s">
                    <!-- section title start -->
                    <div class="section-title">
                        <span class="sub-title">{subTitle}</span>
                        <h2>{title} {titleAccent && <span>{titleAccent}</span>}</h2>
                        {desc && <p>{desc}</p>}
                        {paragraphs.map((p) => <p>{p}</p>)}
                    </div>
                    <!-- section title end -->

                    {features.length > 0 && (
                        <div class="about-features-wappper">
                            {features.map((feature, index) => (
                                <div class="about-features-item">
                                    <div class="about-features-icon">
                                        <figure>
                                            <img src={feature.icon || `/assets/images/about/icon-2-${(index % 2) + 1}-1.png`} alt={feature.title} />
                                        </figure>
                                    </div>
                                    <div class="about-features-title">
                                        <h3>{feature.title}</h3>
                                        <p>{feature.desc}</p>
                                    </div>
                                </div>
                            ))}
                        </div>
                    )}

                    {phone && (
                        <div class="about-footer">
                            <div class="about-contact-box">
                                <div class="icon-box">
                                    <i class="fa-solid fa-phone"></i>
                                </div>
                                <div class="about-contact-box-content">
                                    <p>{phoneLabel}</p>
                                    <a href={`tel:${phone.replace(/\s+/g, "")}`}>{phone}</a>
                                </div>
                            </div>
                        </div>
                    )}
                </div>
                <!-- about left end -->
            </div>
            <div class="col-lg-6">
                <!-- about right start -->
                <div class="about-right wow fadeInUp" data-wow-delay=".3s">
                    {contentItems.length > 0 && (
                        <div class="about-content-box">
                            {contentItems.map((item, index) => (
                                <div class={`about-content-item ${index < contentItems.length - 1 ? "mb-30" : ""}`}>
                                    <p class="about-text">{item.title}</p>
                                    <p class="desc">{item.desc}</p>
                                </div>
                            ))}
                        </div>
                    )}
                    <!-- about image start -->
                    <div class="about-image-2">
                        <figure class="image-anime">
                            <img src={image} alt={contentTitle || title} />
                        </figure>
                    </div>
                    <!-- about image end -->
                </div>
                <!-- about right end -->
            </div>
        </div>
    </div>
</section>
<!-- about section end -->
