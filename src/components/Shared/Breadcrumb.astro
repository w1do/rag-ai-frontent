---
export interface BreadcrumbItem {
    name: string;
    url?: string;
}

export interface Props {
    title: string;
    items?: BreadcrumbItem[];
}

const { title, items } = Astro.props;

const defaultItems: BreadcrumbItem[] = [
    { name: "Главная", url: "/" },
    { name: title }
];

const paths = items || defaultItems;
---

<!-- breadcrumb section start -->
<section class="breadcrumb-section pt-100 md-pt-80 pb-100 md-pb-80" data-img-src="/assets/images/breadcrumb/breadcrumb-shape-line.png">
    <div class="container">
        <div class="row">
            <div class="col-lg-12">
                <!-- breadcrumb content start -->
                <div class="breadcrumb-content">
                    <!-- breadcrumb title start -->
                    <div class="breadcrumb-title wow fadeInUp" data-wow-delay=".2s">
                        <h1>{title}</h1>
                    </div>
                    <!-- breadcrumb title end -->
                    <!-- nav start -->
                    <nav aria-label="breadcrumb" class="wow fadeInUp" data-wow-delay=".3s">
                        <ol class="breadcrumb">
                            {paths.map((item, index) => {
                                const isLast = index === paths.length - 1;
                                return (
                                    <li class={`breadcrumb-item ${isLast ? 'active' : ''}`} aria-current={isLast ? "page" : undefined}>
                                        {item.url ? <a href={item.url}>{item.name}</a> : item.name}
                                    </li>
                                );
                            })}
                        </ol>
                    </nav>
                    <!-- nav end -->
                </div>
                <!-- breadcrumb content end -->
            </div>
        </div>
    </div>
    <div class="breadcrumb-shape">
        <img class="breadcrumb-shape-one" src="/assets/images/breadcrumb/breadcrumb-shape-1.png" alt="breadcrumb shape one">
        <img class="breadcrumb-shape-two" src="/assets/images/breadcrumb/breadcrumb-shape-2.png" alt="breadcrumb shape two">
        <img class="breadcrumb-shado-top" src="/assets/images/breadcrumb/breadcrumb-shado-top.png" alt="breadcrumb shape top">
        <img class="breadcrumb-shado-bottom" src="/assets/images/breadcrumb/breadcrumb-shado-bottom.png" alt="breadcrumb shape bottom">
    </div>
</section>
<!-- breadcrumb section end -->
