---
interface GeneratorItem {
    icon: string;
    title: string;
    desc: string;
}

interface Props {
    subTitle?: string;
    titlePre?: string;
    titleAccent?: string;
    titlePost?: string;
    items?: GeneratorItem[];
    btnText?: string;
    btnLink?: string;
}

const {
    subTitle = "Возможности платформы",
    titlePre = "Что такое ",
    titleAccent = "RAG-агент",
    titlePost = " BotSync?",
    items = [
        {
            icon: "assets/images/image-generator/icon-1.png",
            title: "Интеллектуальная база знаний",
            desc: "Ваш чат-бот мгновенно извлекает информацию из PDF, Excel, JSON и текстовых файлов, предоставляя точные ответы клиентам 24/7 без галлюцинаций."
        },
        {
            icon: "assets/images/image-generator/icon-2.png",
            title: "От данных <br> к диалогу",
            desc: "Просто загрузите ссылку на ваш сайт или файл. Наша система автоматически проиндексирует данные и создаст экспертного консультанта для вашего бизнеса."
        },
        {
            icon: "assets/images/image-generator/icon-3.png",
            title: "Создано для бизнеса и команд",
            desc: "BotSync легко интегрируется в CRM, мессенджеры и сайты. Это идеальное решение для отделов продаж, техподдержки и HR-департаментов."
        }
    ],
    btnText = "Начать бесплатно",
    btnLink = "#contact"
} = Astro.props;
---
<!-- image generator section start -->
<section id="possibilities" class="image-generator-section pt-100 md-pt-80 pb-100 md-pb-80">
    <div class="container">
        <div class="row">
            <div class="col-lg-12">
                <!-- section title start -->
                <div class="section-title text-center wow fadeInUp" data-wow-delay=".2s">
                    <span class="sub-title">{subTitle}</span>
                    <h2>{titlePre}<span>{titleAccent}</span>{titlePost}</h2>
                </div>
                <!-- section title end -->
            </div>
        </div>
        <div class="row">
            <div class="col-lg-12">
                <div class="image-generator-wapper">
                    {items.map((item, index) => (
                        <div class="image-generator-items right-after wow fadeInUp" data-wow-delay={`${0.3 + index * 0.1}s`}>
                            <div class="image-generator-icon">
                                <figure>
                                    <img src={item.icon} alt={item.title}>
                                </figure>
                            </div>
                            <div class="image-generator-content">
                                <h2 fragment set:html={item.title}></h2>
                                <p>{item.desc}</p>
                            </div>
                        </div>
                    ))}
                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-lg-12">
                <!-- image generator footer start -->
                <div class="image-generator-footer mt-30 wow fadeInUp" data-wow-delay=".6s">
                    <div class="image-generator-button text-center">
                        <a href={btnLink} class="theme-button style-1" aria-label={btnText}>
                            <span data-text={btnText}>{btnText}</span>
                            <i class="fa-solid fa-arrow-right"></i>
                        </a>
                    </div>
                </div>
                <!-- image generator footer end -->
            </div>
        </div>
    </div>
</section>
<!-- image generator section end -->