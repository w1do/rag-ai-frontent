                        </div>
                        <!-- footer copyright end -->
                    </div>
                    <div class="col-lg-6 text-lg-end">
                        <!-- footer bottom nav start -->
                        <ul class="footer-bottom-nav wow fadeInUp" data-wow-delay=".3s">
                            <li><a class="line-effect" href="/terms">Условия использования</a></li>
                            <li><a class="line-effect" href="/privacy">Политика конфиденциальности</a></li>
                        </ul>
                        <!-- footer bottom nav end -->
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!-- footer copyright end -->
</footer>
<!-- footer end -->