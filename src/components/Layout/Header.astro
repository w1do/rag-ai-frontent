---
import { getCollection } from 'astro:content';

const possibilities = await getCollection('possibilities');
const sortedPossibilities = possibilities.sort((a, b) => a.data.order - b.data.order);

interface Bot {
    id: number;
    name: string;
    slug: string;
    description?: string;
}

let bots: Bot[] = [];
try {
    const res = await fetch(`${import.meta.env.PUBLIC_API_BASE}/chats`, {
        headers: {
            'accept': 'application/json'
        }
    });
    if (res.ok) {
        const data = await res.json();
        bots = data.data || [];
    }
} catch (e) {
    console.error('Error fetching bots:', e);
}

// В шапке показываем только 10 примеров ботов
const headerBots = bots.slice(0, 10);
